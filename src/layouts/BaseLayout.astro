---
/**
 * BaseLayout — sistema de diseño unificado de "Exámenes UNIR".
 * Porta el sistema común de los HTML originales: topbar con nav-a-root,
 * toggle claro/oscuro con persistencia en localStorage('site-theme'),
 * tokens --site-*, skip-link de accesibilidad y script anti-parpadeo.
 */
export interface Props {
  title: string;
  description?: string;
  /** Color de acento de la asignatura (opcional). */
  accent?: string;
  /** Título corto mostrado en la topbar junto al brand (opcional). */
  docTitle?: string;
  /** Muestra el enlace "nav-a-root" en la topbar (true en páginas de detalle). */
  home?: boolean;
}

const {
  title,
  description = 'Material de estudio por asignatura: esquemas y práctica de examen.',
  accent,
  docTitle,
  home = false,
} = Astro.props;

const base = '/';
const accentStyle = accent ? `--site-accent:${accent}` : undefined;
---

<!doctype html>
<html lang="es" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="data:," />
    <slot name="head" />
    <script is:inline>
      /* Tema: inicializa antes de pintar para evitar parpadeo */
      (function () {
        try {
          var t = localStorage.getItem('site-theme');
          if (!t) {
            t =
              window.matchMedia &&
              window.matchMedia('(prefers-color-scheme: dark)').matches
                ? 'dark'
                : 'light';
          }
          document.documentElement.setAttribute('data-theme', t);
        } catch (e) {}
      })();
    </script>
  </head>
  <body style={accentStyle}>
    <a class="skip" href="#main">Saltar al contenido</a>

    <div class="site-topbar">
      <a class="site-brand" href={base}>
        <span class="dot"></span>Exámenes UNIR
      </a>
      {docTitle && <span class="site-doc-title">{docTitle}</span>}
      <span class="site-spacer"></span>
      {
        home && (
          <a class="site-home" href={base}>
            ← Inicio
          </a>
        )
      }
      <button
        class="site-theme-toggle"
        type="button"
        aria-label="Cambiar tema claro/oscuro"
        title="Cambiar tema"
      >
        <span class="site-ic-sun" aria-hidden="true">☀</span>
        <span class="site-ic-moon" aria-hidden="true">☾</span>
      </button>
    </div>

    <main id="main">
      <slot />
    </main>

    <script is:inline>
      /* Toggle de tema (común) */
      (function () {
        var b = document.querySelector('.site-theme-toggle');
        if (!b) return;
        b.addEventListener('click', function () {
          var d = document.documentElement;
          var n = d.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
          d.setAttribute('data-theme', n);
          try {
            localStorage.setItem('site-theme', n);
          } catch (e) {}
        });
      })();
    </script>
  </body>
</html>

<style is:global>
  /* ===== Sistema común: design tokens + tema claro/oscuro ===== */
  :root {
    --site-accent: #5a5fd6; /* acento neutro por defecto (contraste AA) */
    --site-radius: 14px;
    --site-sans: -apple-system, 'Segoe UI', Inter, Roboto, Helvetica, Arial, sans-serif;
  }
  :root[data-theme='light'] {
    --site-bg: #eef1f0;
    --site-surface: #ffffff;
    --site-surface-2: #f3f6f6;
    --site-ink: #10212b;
    --site-muted: #5e7079;
    --site-line: #d9e0df;
    --site-topbar-bg: #10212b;
    --site-topbar-ink: #eef4f4;
    --site-topbar-line: rgba(255, 255, 255, 0.16);
    --site-shadow: 0 1px 2px rgba(16, 33, 43, 0.05);
    --site-shadow-lg: 0 10px 30px rgba(16, 33, 43, 0.1);
    --site-ok: #1c8a5b;
    --site-ok-soft: #ddf1e7;
    --site-bad: #c8384b;
    --site-bad-soft: #f8dee2;
  }
  :root[data-theme='dark'] {
    --site-bg: #0f1417;
    --site-surface: #161d21;
    --site-surface-2: #1d262b;
    --site-ink: #e7eef0;
    --site-muted: #9fb1b6;
    --site-line: #283238;
    --site-topbar-bg: #0a0e10;
    --site-topbar-ink: #e7eef0;
    --site-topbar-line: rgba(255, 255, 255, 0.12);
    --site-shadow: 0 1px 2px rgba(0, 0, 0, 0.4);
    --site-shadow-lg: 0 12px 32px rgba(0, 0, 0, 0.5);
    --site-ok: #4dbf86;
    --site-ok-soft: #16291f;
    --site-bad: #e06576;
    --site-bad-soft: #33191d;
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }
  body {
    font-family: var(--site-sans);
    background: var(--site-bg);
    color: var(--site-ink);
    min-height: 100vh;
  }
  a {
    color: inherit;
  }

  /* ===== Skip link (accesibilidad) ===== */
  .skip {
    position: absolute;
    left: -9999px;
    top: 0;
    z-index: 2000;
    background: var(--site-surface);
    color: var(--site-ink);
    border: 1px solid var(--site-line);
    border-radius: 9px;
    padding: 10px 14px;
    font-weight: 600;
    text-decoration: none;
  }
  .skip:focus {
    left: 12px;
    top: 10px;
  }

  /* ===== Topbar común (nav-a-root + toggle de tema) ===== */
  .site-topbar {
    position: sticky;
    top: 0;
    z-index: 1000;
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 10px 18px;
    background: var(--site-topbar-bg);
    color: var(--site-topbar-ink);
    border-bottom: 2px solid var(--site-accent);
    font-family: var(--site-sans);
  }
  .site-topbar .site-brand {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-weight: 700;
    font-size: 14px;
    text-decoration: none;
    color: inherit;
  }
  .site-topbar .site-brand .dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--site-accent);
  }
  .site-doc-title {
    font-size: 13px;
    font-weight: 600;
    opacity: 0.82;
  }
  .site-spacer {
    margin-right: auto;
  }
  .site-home {
    color: inherit;
    text-decoration: none;
    font-weight: 600;
    font-size: 13px;
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 6px 12px;
    border-radius: 9px;
    border: 1px solid var(--site-topbar-line);
    transition: background 0.15s;
  }
  .site-home:hover {
    background: rgba(255, 255, 255, 0.12);
  }
  .site-theme-toggle {
    cursor: pointer;
    background: transparent;
    color: inherit;
    border: 1px solid var(--site-topbar-line);
    border-radius: 9px;
    width: 40px;
    height: 34px;
    font-size: 15px;
    line-height: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s;
  }
  .site-theme-toggle:hover {
    background: rgba(255, 255, 255, 0.12);
  }
  .site-theme-toggle:focus-visible {
    outline: 2px solid #fff;
    outline-offset: 2px;
  }
  :root[data-theme='light'] .site-ic-moon {
    display: none;
  }
  :root[data-theme='dark'] .site-ic-sun {
    display: none;
  }

  /* ===== Contenedor principal ===== */
  main {
    max-width: 1000px;
    margin: 0 auto;
    padding: 2.75rem 1.25rem 4rem;
  }

  @media (prefers-reduced-motion: reduce) {
    * {
      transition: none !important;
    }
  }
</style>
