---
/**
 * BaseLayout — sistema de diseño unificado de PlanchaAPP.
 * Porta el sistema común de los HTML originales: topbar con nav-a-root,
 * toggle claro/oscuro con persistencia en localStorage('site-theme'),
 * tokens --site-*, skip-link de accesibilidad y script anti-parpadeo.
 */
import { BASE, SITE, SITE_NAME, canonicalUrl } from '../data/site';
import SearchBox from '../components/SearchBox.astro';

export interface Props {
  title: string;
  description?: string;
  /** Color de acento de la asignatura (opcional). */
  accent?: string;
  /** Título corto mostrado en la topbar junto al brand (opcional). */
  docTitle?: string;
  /** Muestra el enlace "nav-a-root" en la topbar (true en páginas de detalle). */
  home?: boolean;
}

const {
  title,
  description = 'Material de estudio por asignatura: esquemas y práctica de examen.',
  accent,
  docTitle,
  home = false,
} = Astro.props;

const base = `${BASE}/`;
const accentStyle = accent ? `--site-accent:${accent}` : undefined;
// `Astro.url.pathname` already includes BASE (Astro resolves it under the
// configured base), so it's joined with SITE directly — routing it through
// `canonicalUrl()`/`url()` would prepend BASE a second time.
const pageUrl = `${SITE}${Astro.url.pathname}`;
---

<!doctype html>
<html lang="es" data-theme="light" data-theme-pref="auto">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${BASE}/favicon.svg`} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:image" content={canonicalUrl('/og-image.png')} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={canonicalUrl('/og-image.png')} />

    <slot name="head" />
    <script is:inline>
      /* Tema: inicializa antes de pintar para evitar parpadeo.
         `site-theme` guarda la preferencia ('light'|'dark'|'auto', 'auto'
         por defecto sin nada guardado); `data-theme` es el tema visual
         resuelto y `data-theme-pref` la preferencia cruda (para el icono). */
      (function () {
        try {
          const pref = localStorage.getItem('site-theme') || 'auto';
          const resolved =
            pref === 'auto'
              ? window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches
                ? 'dark'
                : 'light'
              : pref;
          document.documentElement.setAttribute('data-theme', resolved);
          document.documentElement.setAttribute('data-theme-pref', pref);
        } catch (e) {}
      })();
    </script>
  </head>
  <body style={accentStyle}>
    <a class="skip" href="#main">Saltar al contenido</a>

    <div class="site-topbar">
      <a class="site-brand" href={base}>
        <span class="dot"></span>{SITE_NAME}
      </a>
      {docTitle && <span class="site-doc-title">{docTitle}</span>}
      <SearchBox />
      <span class="site-spacer"></span>
      {
        home && (
          <a class="site-home" href={base}>
            ← Inicio
          </a>
        )
      }
      <button
        class="site-theme-toggle"
        type="button"
        aria-label="Cambiar tema (claro/oscuro/automático)"
        title="Cambiar tema"
      >
        <span class="site-ic-sun" aria-hidden="true">☀</span>
        <span class="site-ic-moon" aria-hidden="true">☾</span>
        <span class="site-ic-auto" aria-hidden="true">◐</span>
      </button>
    </div>

    <main id="main">
      <slot />
    </main>

    <script is:inline>
      /* Toggle de tema (común): cicla claro → oscuro → automático → claro…
         En modo automático, sigue prefers-color-scheme también en vivo. */
      (function () {
        const b = document.querySelector('.site-theme-toggle');
        if (!b) return;
        const d = document.documentElement;
        const ORDER = ['light', 'dark', 'auto'];

        function resolve(pref) {
          if (pref !== 'auto') return pref;
          return window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches
            ? 'dark'
            : 'light';
        }

        function apply(pref) {
          d.setAttribute('data-theme-pref', pref);
          d.setAttribute('data-theme', resolve(pref));
        }

        b.addEventListener('click', function () {
          const current = d.getAttribute('data-theme-pref') || 'auto';
          const next = ORDER[(ORDER.indexOf(current) + 1) % ORDER.length];
          apply(next);
          try {
            localStorage.setItem('site-theme', next);
          } catch (e) {}
        });

        const mq = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)');
        if (mq && mq.addEventListener) {
          mq.addEventListener('change', function (e) {
            if (d.getAttribute('data-theme-pref') === 'auto') {
              d.setAttribute('data-theme', e.matches ? 'dark' : 'light');
            }
          });
        }
      })();
    </script>
  </body>
</html>

<style is:global>
  /* ===== Sistema común: design tokens + tema claro/oscuro ===== */
  :root {
    --site-accent: #5a5fd6; /* acento neutro por defecto (contraste AA) */
    --site-radius: 14px;
    --site-sans: -apple-system, 'Segoe UI', Inter, Roboto, Helvetica, Arial, sans-serif;
    --mm-pin: #e0a400; /* minimap: distinct from --site-accent/--site-ok/--site-bad so pins never collide with grading colors */
  }
  :root[data-theme='light'] {
    --site-bg: #eef1f0;
    --site-surface: #ffffff;
    --site-surface-2: #f3f6f6;
    --site-ink: #10212b;
    --site-muted: #5e7079;
    --site-line: #d9e0df;
    --site-topbar-bg: #10212b;
    --site-topbar-ink: #eef4f4;
    --site-topbar-line: rgba(255, 255, 255, 0.16);
    --site-shadow: 0 1px 2px rgba(16, 33, 43, 0.05);
    --site-shadow-lg: 0 10px 30px rgba(16, 33, 43, 0.1);
    --site-ok: #1c8a5b;
    --site-ok-soft: #ddf1e7;
    --site-bad: #c8384b;
    --site-bad-soft: #f8dee2;
  }
  :root[data-theme='dark'] {
    --site-bg: #0f1417;
    --site-surface: #161d21;
    --site-surface-2: #1d262b;
    --site-ink: #e7eef0;
    --site-muted: #9fb1b6;
    --site-line: #283238;
    --site-topbar-bg: #0a0e10;
    --site-topbar-ink: #e7eef0;
    --site-topbar-line: rgba(255, 255, 255, 0.12);
    --site-shadow: 0 1px 2px rgba(0, 0, 0, 0.4);
    --site-shadow-lg: 0 12px 32px rgba(0, 0, 0, 0.5);
    --site-ok: #4dbf86;
    --site-ok-soft: #16291f;
    --site-bad: #e06576;
    --site-bad-soft: #33191d;
    --mm-pin: #f0b400;
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }
  body {
    font-family: var(--site-sans);
    background: var(--site-bg);
    color: var(--site-ink);
    min-height: 100vh;
  }
  a {
    color: inherit;
  }

  /* ===== Skip link (accesibilidad) ===== */
  .skip {
    position: absolute;
    left: -9999px;
    top: 0;
    z-index: 2000;
    background: var(--site-surface);
    color: var(--site-ink);
    border: 1px solid var(--site-line);
    border-radius: 9px;
    padding: 10px 14px;
    font-weight: 600;
    text-decoration: none;
  }
  .skip:focus {
    left: 12px;
    top: 10px;
  }

  /* ===== Topbar común (nav-a-root + toggle de tema) ===== */
  .site-topbar {
    position: sticky;
    top: 0;
    z-index: 1000;
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 10px 18px;
    background: var(--site-topbar-bg);
    color: var(--site-topbar-ink);
    border-bottom: 2px solid var(--site-accent);
    font-family: var(--site-sans);
  }
  .site-topbar .site-brand {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-weight: 700;
    font-size: 14px;
    text-decoration: none;
    color: inherit;
    flex-shrink: 0;
  }
  .site-topbar .site-brand .dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--site-accent);
  }
  .site-doc-title {
    font-size: 13px;
    font-weight: 600;
    opacity: 0.82;
    /* Truncate instead of wrapping to two lines when the topbar is tight
       (which grows its height and squeezes the other controls). `min-width:
       0` is required: flex items default to `min-width: auto` (their content
       size), which would otherwise stop this from shrinking at all. */
    min-width: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .site-spacer {
    margin-right: auto;
  }
  .site-home {
    color: inherit;
    text-decoration: none;
    font-weight: 600;
    font-size: 13px;
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 6px 12px;
    border-radius: 9px;
    border: 1px solid var(--site-topbar-line);
    transition: background 0.15s;
    flex-shrink: 0;
    white-space: nowrap;
  }
  .site-home:hover {
    background: rgba(255, 255, 255, 0.12);
  }
  .site-theme-toggle {
    cursor: pointer;
    background: transparent;
    color: inherit;
    border: 1px solid var(--site-topbar-line);
    border-radius: 9px;
    width: 40px;
    height: 34px;
    font-size: 15px;
    line-height: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s;
    flex-shrink: 0;
  }
  .site-theme-toggle:hover {
    background: rgba(255, 255, 255, 0.12);
  }
  .site-theme-toggle:focus-visible {
    outline: 2px solid #fff;
    outline-offset: 2px;
  }
  /* Icono del toggle: refleja la preferencia elegida (claro/oscuro/automático),
     no el tema visual resuelto — así "automático" tiene su propio icono
     aunque el sistema esté en claro u oscuro. */
  .site-ic-sun,
  .site-ic-moon,
  .site-ic-auto {
    display: none;
  }
  :root[data-theme-pref='light'] .site-ic-sun {
    display: inline;
  }
  :root[data-theme-pref='dark'] .site-ic-moon {
    display: inline;
  }
  :root[data-theme-pref='auto'] .site-ic-auto {
    display: inline;
  }

  /* ===== Contenedor principal ===== */
  main {
    max-width: 1000px;
    margin: 0 auto;
    padding: 2.75rem 1.25rem 4rem;
  }

  @media (prefers-reduced-motion: reduce) {
    * {
      transition: none !important;
    }
  }
</style>
