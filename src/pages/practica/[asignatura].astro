---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TestQuestion from '../../components/TestQuestion.astro';
import DesarrolloQuestion from '../../components/DesarrolloQuestion.astro';
import Minimap from '../../components/Minimap.astro';
import { meta } from '../../data/asignaturas';
import { uniqueTemas } from '../../lib/practica-temas';

export async function getStaticPaths() {
  const test = await getCollection('test');
  const desarrollo = await getCollection('desarrollo');
  const guia = await getCollection('guia');
  // Las asignaturas con guía exponen su test como quiz dentro de la guía.
  const guiaCodes = new Set(guia.map((g) => g.data.asignatura));
  const codes = new Set<string>(
    [...test.map((t) => t.data.asignatura), ...desarrollo.map((d) => d.data.asignatura)].filter(
      (c) => !guiaCodes.has(c),
    ),
  );

  const byNum = (a: string, b: string) => a.localeCompare(b, 'es', { numeric: true });

  return Array.from(codes).map((code) => {
    const tests = test
      .filter((t) => t.data.asignatura === code)
      .sort((a, b) => byNum(a.data.id, b.data.id));
    const devs = desarrollo
      .filter((d) => d.data.asignatura === code)
      .sort((a, b) => a.data.orden - b.data.orden);
    return { params: { asignatura: code }, props: { code, tests, devs } };
  });
}

const { code, tests, devs } = Astro.props;
const m = meta(code);
const temas = uniqueTemas(tests.map((t) => t.data.tema));

// Renderiza el cuerpo (respuesta modelo) de cada desarrollo.
const devsRendered = await Promise.all(
  devs.map(async (d) => ({ data: d.data, Content: (await render(d)).Content })),
);
---

<BaseLayout
  title={`${m.sigla} · Práctica de examen`}
  accent={m.accent}
  docTitle={`${m.sigla} · Práctica`}
  home={true}
>
  <header class="ph">
    <span class="ph-sigla">{m.sigla}</span>
    <h1>{m.nombre}</h1>
    <p class="ph-sub">
      {tests.length > 0 && <span>{tests.length} preguntas tipo test</span>}
      {tests.length > 0 && devs.length > 0 && <span> · </span>}
      {devs.length > 0 && <span>{devs.length} de desarrollo</span>}
    </p>
  </header>

  {
    tests.length > 0 && (
      <section class="block" aria-labelledby="h-test" data-practica={code}>
        <h2 class="block-h" id="h-test">
          <span class="block-idx">I</span> Preguntas tipo test
        </h2>
        <p class="block-desc">
          Marca una opción (o varias en las de selección múltiple) y pulsa «Corregir». ¿Solo quieres
          comprobar una? Pulsa «Ver respuesta» en esa pregunta: la solución se muestra unos segundos
          y se oculta sola.
        </p>

        <details class="panel stats" data-stats>
          <summary class="panel-summary">
            <span class="panel-title">Estadísticas</span>
            <span class="panel-chip" data-stats-chip />
          </summary>
          <div class="panel-body">
            <p class="stats-summary" data-stats-summary />
            <div class="stats-actions">
              <label class="stats-toggle">
                <input type="checkbox" data-failed-toggle /> Solo mis fallos
              </label>
              <button class="btn-reset" type="button" data-stats-reset>
                Reiniciar estadísticas
              </button>
            </div>
          </div>
        </details>

        <details class="panel exam" data-exam-panel>
          <summary class="panel-summary">
            <span class="panel-title">Modo examen</span>
            <span class="panel-chip" data-exam-chip />
          </summary>
          <div class="panel-body">
            <div class="exam-opts">
              <label class="exam-opt">
                <input type="checkbox" data-exam-shuffle /> Barajar preguntas
              </label>
              <label class="exam-opt">
                <input type="checkbox" data-exam-subset-toggle /> Subconjunto de
                <input
                  type="number"
                  min="1"
                  max={tests.length}
                  value={tests.length}
                  data-exam-subset-n
                  disabled
                />{' '}
                preguntas
              </label>
              <label class="exam-opt">
                <input type="checkbox" data-exam-timed /> Cronometrado, minutos:
                <input type="number" min="1" value="20" data-exam-minutes disabled />
              </label>
            </div>
            <div class="exam-actions">
              <button class="btn-grade" type="button" data-exam-start>
                {' '}
                Empezar simulacro{' '}
              </button>
              <button class="btn-reset" type="button" data-exam-exit hidden>
                Salir de modo examen
              </button>
              <span class="exam-timer" role="status" aria-live="polite" data-exam-timer />
            </div>
          </div>
        </details>

        {temas.length > 0 && (
          <div class="tema-filters" role="group" aria-label="Filtrar por tema" data-tema-filters>
            <button class="filter-btn on" type="button" data-tema-filter="all" aria-pressed="true">
              Todos
            </button>
            {temas.map((t) => (
              <button class="filter-btn" type="button" data-tema-filter={t} aria-pressed="false">
                {t}
              </button>
            ))}
          </div>
        )}

        {tests.map((q, i) => (
          <TestQuestion
            id={q.data.id}
            type={q.data.type}
            question={q.data.question}
            options={q.data.options}
            correct={q.data.correct}
            explicacion={q.data.explicacion}
            tema={q.data.tema}
            num={i + 1}
          />
        ))}
        <div class="test-foot">
          <button class="btn-grade" type="button" data-grade-trigger>
            Corregir test
          </button>
          <button class="btn-reset" type="button" data-reset-trigger>
            Reiniciar progreso
          </button>
          <span class="score" role="status" aria-live="polite" />
        </div>
      </section>
    )
  }

  {
    devsRendered.length > 0 && (
      <section class="block" aria-labelledby="h-dev" data-desarrollo={code}>
        <h2 class="block-h" id="h-dev">
          <span class="block-idx">{tests.length > 0 ? 'II' : 'I'}</span> Preguntas de desarrollo
        </h2>
        <p class="block-desc">Escribe tu respuesta y contrástala con la respuesta modelo.</p>

        <details class="panel stats" data-dev-stats>
          <summary class="panel-summary">
            <span class="panel-title">Autoevaluación</span>
            <span class="panel-chip" data-dev-chip />
          </summary>
          <div class="panel-body">
            <p class="stats-summary" data-dev-stats-summary />
          </div>
        </details>

        {devsRendered.map((d, i) => (
          <DesarrolloQuestion
            id={d.data.id}
            enunciado={d.data.enunciado}
            titulo={d.data.titulo}
            kind={d.data.kind}
            tema={d.data.tema}
            num={i + 1}
          >
            <d.Content />
          </DesarrolloQuestion>
        ))}
      </section>
    )
  }

  {
    (tests.length > 0 || devsRendered.length > 0) && (
      <Minimap scope={`practica-${code}`} kind="practica" />
    )
  }
</BaseLayout>

<script>
  import {
    statsKeyFor,
    parseStats,
    summarize,
    failedIds,
    formatStatsChip,
  } from '../../lib/practica-stats';
  import {
    keyFor as devKeyFor,
    parse as parseDevProgress,
    summarize as summarizeDevProgress,
    formatDevChip,
  } from '../../lib/desarrollo-progress';
  import {
    createRng,
    buildExamOrder,
    examConfigKeyFor,
    serializeExamConfig,
    parseExamConfig,
    formatExamConfigSummary,
    type ExamConfig,
  } from '../../lib/exam-mode';

  document.addEventListener('tq:graded', (e) => {
    const { score, total } = (e as CustomEvent).detail;
    const el = document.querySelector('.score');
    if (el) el.textContent = `Aciertos: ${score} / ${total}`;
  });

  // --- Stats summary panel (per asignatura) ---------------------------------
  const asignatura = document.querySelector('[data-practica]')?.getAttribute('data-practica') ?? '';
  const summaryEl = document.querySelector<HTMLElement>('[data-stats-summary]');

  function safeGet(key: string): string | null {
    try {
      return localStorage.getItem(key);
    } catch {
      return null;
    }
  }
  function safeSet(key: string, value: string): void {
    try {
      localStorage.setItem(key, value);
    } catch {
      /* no-op */
    }
  }
  function safeRemove(key: string): void {
    try {
      localStorage.removeItem(key);
    } catch {
      /* no-op */
    }
  }

  const pct = (x: number) => `${Math.round(x * 100)}%`;

  // Maps a question id ("q-<id>") to its displayed number, read from the DOM.
  function questionNum(id: string): string {
    return document.getElementById(id)?.querySelector('.tq-num')?.textContent?.trim() ?? '?';
  }

  function renderStats(): void {
    if (!asignatura || !summaryEl) return;
    const total = document.querySelectorAll('[data-tq]').length;
    const state = parseStats(safeGet(statsKeyFor(asignatura)));
    const sum = state && summarize(state);
    if (!sum || sum.answered === 0) {
      summaryEl.textContent =
        'Aún no has corregido preguntas. Corrige el test para ver tus estadísticas.';
      return;
    }
    const top = sum.mostFailed
      .slice(0, 5)
      .map((m) => `<a href="#${m.id}">${questionNum(m.id)}</a> (×${m.wrong})`)
      .join(' · ');
    summaryEl.innerHTML =
      `<strong>Respondidas:</strong> ${sum.answered} de ${total} · ` +
      `<strong>Acierto último intento:</strong> ${pct(sum.accuracyLast)} · ` +
      `<strong>Acumulado:</strong> ${pct(sum.accuracyAll)}` +
      (top ? `<br /><strong>Más falladas:</strong> ${top}` : '');
  }

  // «Solo mis fallos»: show only questions whose last attempt was wrong.
  const failedToggle = document.querySelector<HTMLInputElement>('[data-failed-toggle]');

  function applyFailedFilter(): void {
    if (!asignatura) return;
    const on = failedToggle?.checked ?? false;
    const state = parseStats(safeGet(statsKeyFor(asignatura)));
    const failed = new Set(state ? failedIds(state) : []);
    document.querySelectorAll<HTMLElement>('[data-tq]').forEach((q) => {
      q.hidden = on && !failed.has(q.id);
    });
    document.dispatchEvent(new CustomEvent('practica:filter-changed'));
  }

  // Exam mode, the topic filter, and «solo mis fallos» all drive `hidden` on
  // the same `[data-tq]` elements — mutually exclusive so they never fight.
  failedToggle?.addEventListener('change', () => {
    if (failedToggle.checked) {
      if (examActive) exitExam();
      resetTemaButtons();
    }
    applyFailedFilter();
  });

  // Reset stats only (independent of the answers progress reset of #8).
  document.querySelector('[data-stats-reset]')?.addEventListener('click', () => {
    if (asignatura) safeRemove(statsKeyFor(asignatura));
    if (failedToggle) failedToggle.checked = false;
    applyFailedFilter();
    renderStats();
  });

  document.addEventListener('practica:stats-updated', renderStats);
  renderStats();

  // --- Self-assessment summary panel (desarrollo, per asignatura) -----------
  const devAsignatura =
    document.querySelector('[data-desarrollo]')?.getAttribute('data-desarrollo') ?? '';
  const devSummaryEl = document.querySelector<HTMLElement>('[data-dev-stats-summary]');

  function renderDevStats(): void {
    if (!devAsignatura || !devSummaryEl) return;
    const state = parseDevProgress(safeGet(devKeyFor(devAsignatura)));
    const sum = state && summarizeDevProgress(state);
    if (!sum || sum.answered === 0) {
      devSummaryEl.textContent = 'Aún no has autoevaluado ninguna pregunta de desarrollo.';
      return;
    }
    devSummaryEl.textContent = `Sabías: ${sum.sabia} · A medias: ${sum.medias} · No sabías: ${sum.no}`;
  }

  document.addEventListener('desarrollo:stats-updated', renderDevStats);
  renderDevStats();

  // --- Exam mode (shuffle / N-question subset / timed simulacro) ------------
  const examStartBtn = document.querySelector<HTMLButtonElement>('[data-exam-start]');
  const examExitBtn = document.querySelector<HTMLButtonElement>('[data-exam-exit]');
  const examShuffleCheckbox = document.querySelector<HTMLInputElement>('[data-exam-shuffle]');
  const examSubsetToggle = document.querySelector<HTMLInputElement>('[data-exam-subset-toggle]');
  const examSubsetN = document.querySelector<HTMLInputElement>('[data-exam-subset-n]');
  const examTimedCheckbox = document.querySelector<HTMLInputElement>('[data-exam-timed]');
  const examMinutesInput = document.querySelector<HTMLInputElement>('[data-exam-minutes]');
  const examTimerEl = document.querySelector<HTMLElement>('[data-exam-timer]');
  const testSection = document.querySelector<HTMLElement>('[data-practica]');
  // Original order/visibility of the questions, captured once so «Salir de
  // modo examen» can restore it exactly regardless of what the simulacro did.
  const originalOrder = testSection
    ? Array.from(testSection.querySelectorAll<HTMLElement>('[data-tq]'))
    : [];
  let examActive = false;

  // Enable a paired number input only while its checkbox is checked.
  function wireToggle(checkbox: HTMLInputElement | null, input: HTMLInputElement | null): void {
    if (!checkbox || !input) return;
    checkbox.addEventListener('change', () => {
      input.disabled = !checkbox.checked;
    });
  }
  wireToggle(examSubsetToggle, examSubsetN);
  wireToggle(examTimedCheckbox, examMinutesInput);

  let examTimerId: number | null = null;

  function stopTimer(): void {
    if (examTimerId !== null) {
      clearInterval(examTimerId);
      examTimerId = null;
    }
    if (examTimerEl) examTimerEl.textContent = '';
  }

  function startTimer(durationMs: number): void {
    const endAt = Date.now() + durationMs;
    function tick(): void {
      const remaining = endAt - Date.now();
      if (remaining <= 0) {
        stopTimer();
        document.querySelector<HTMLButtonElement>('[data-grade-trigger]')?.click();
        return;
      }
      const totalSeconds = Math.ceil(remaining / 1000);
      const mm = String(Math.floor(totalSeconds / 60)).padStart(2, '0');
      const ss = String(totalSeconds % 60).padStart(2, '0');
      if (examTimerEl) examTimerEl.textContent = `${mm}:${ss}`;
    }
    tick();
    examTimerId = window.setInterval(tick, 250);
  }

  // Stop the countdown as soon as the test is corrected, whether by the timer
  // itself or by the user clicking «Corregir» before time runs out.
  document.addEventListener('tq:graded', stopTimer);

  function startExam(): void {
    const container = originalOrder[0]?.parentElement;
    if (!container) return;
    // Exam mode shares the same `hidden` flag with «solo mis fallos» and the
    // topic filter: starting a simulacro takes over, so drop both first.
    if (failedToggle?.checked) {
      failedToggle.checked = false;
      applyFailedFilter();
    }
    resetTemaButtons();
    const rng = createRng(Date.now());
    const subsetSize = examSubsetToggle?.checked
      ? Math.max(
          1,
          Math.min(Number(examSubsetN?.value ?? originalOrder.length), originalOrder.length),
        )
      : null;
    const order = buildExamOrder(
      originalOrder,
      { shuffle: examShuffleCheckbox?.checked ?? false, subsetSize },
      rng,
    );
    const visible = new Set(order);
    for (const q of originalOrder) q.hidden = !visible.has(q);
    for (const q of order) container.appendChild(q);
    document.dispatchEvent(new CustomEvent('practica:filter-changed'));
    if (examStartBtn) examStartBtn.hidden = true;
    if (examExitBtn) examExitBtn.hidden = false;
    examActive = true;
    if (examTimedCheckbox?.checked) {
      const minutes = Number(examMinutesInput?.value ?? 20);
      startTimer(minutes * 60000);
    }
  }

  function exitExam(): void {
    stopTimer();
    const container = originalOrder[0]?.parentElement;
    if (container) {
      for (const q of originalOrder) {
        q.hidden = false;
        container.appendChild(q);
      }
    }
    document.dispatchEvent(new CustomEvent('practica:filter-changed'));
    if (examStartBtn) examStartBtn.hidden = false;
    if (examExitBtn) examExitBtn.hidden = true;
    examActive = false;
  }

  examStartBtn?.addEventListener('click', startExam);
  examExitBtn?.addEventListener('click', exitExam);

  // Remember the panel's settings (not the in-progress simulacro) per asignatura.
  function saveExamConfig(): void {
    if (!asignatura) return;
    const config: ExamConfig = {
      shuffle: examShuffleCheckbox?.checked ?? false,
      subsetSize: examSubsetToggle?.checked ? Number(examSubsetN?.value ?? 0) : null,
      timed: examTimedCheckbox?.checked ?? false,
      minutes: Number(examMinutesInput?.value ?? 20),
    };
    safeSet(examConfigKeyFor(asignatura), serializeExamConfig(config));
  }

  function restoreExamConfig(): void {
    if (!asignatura) return;
    const config = parseExamConfig(safeGet(examConfigKeyFor(asignatura)));
    if (!config) return;
    if (examShuffleCheckbox) examShuffleCheckbox.checked = config.shuffle;
    if (examSubsetToggle) examSubsetToggle.checked = config.subsetSize !== null;
    if (examSubsetN) {
      if (config.subsetSize !== null) examSubsetN.value = String(config.subsetSize);
      examSubsetN.disabled = config.subsetSize === null;
    }
    if (examTimedCheckbox) examTimedCheckbox.checked = config.timed;
    if (examMinutesInput) {
      examMinutesInput.value = String(config.minutes);
      examMinutesInput.disabled = !config.timed;
    }
  }

  for (const el of [
    examShuffleCheckbox,
    examSubsetToggle,
    examSubsetN,
    examTimedCheckbox,
    examMinutesInput,
  ]) {
    // `input` covers number fields as the user types (no blur needed); `change`
    // covers the checkboxes. Attaching both to every control is harmless.
    el?.addEventListener('input', saveExamConfig);
    el?.addEventListener('change', saveExamConfig);
  }
  restoreExamConfig();

  // --- Compact one-line summaries for the collapsed panels (issue #32) -------
  // These only feed the <summary> chip; they don't touch renderStats /
  // renderDevStats nor the exam-mode logic above.
  const statsChip = document.querySelector<HTMLElement>('[data-stats-chip]');
  function renderStatsChip(): void {
    if (!statsChip || !asignatura) return;
    const state = parseStats(safeGet(statsKeyFor(asignatura)));
    statsChip.textContent = (state && formatStatsChip(summarize(state))) || 'Sin datos aún';
  }
  document.addEventListener('practica:stats-updated', renderStatsChip);
  renderStatsChip();

  const devChip = document.querySelector<HTMLElement>('[data-dev-chip]');
  function renderDevChip(): void {
    if (!devChip || !devAsignatura) return;
    const state = parseDevProgress(safeGet(devKeyFor(devAsignatura)));
    devChip.textContent =
      (state && formatDevChip(summarizeDevProgress(state))) || 'Sin autoevaluar';
  }
  document.addEventListener('desarrollo:stats-updated', renderDevChip);
  renderDevChip();

  const examChip = document.querySelector<HTMLElement>('[data-exam-chip]');
  function renderExamChip(): void {
    if (!examChip) return;
    const config: ExamConfig | null = examShuffleCheckbox
      ? {
          shuffle: examShuffleCheckbox.checked,
          subsetSize: examSubsetToggle?.checked ? Number(examSubsetN?.value ?? 0) : null,
          timed: examTimedCheckbox?.checked ?? false,
          minutes: Number(examMinutesInput?.value ?? 20),
        }
      : null;
    examChip.textContent = formatExamConfigSummary(config) || 'Sin configurar';
  }
  for (const el of [
    examShuffleCheckbox,
    examSubsetToggle,
    examSubsetN,
    examTimedCheckbox,
    examMinutesInput,
  ]) {
    el?.addEventListener('input', renderExamChip);
    el?.addEventListener('change', renderExamChip);
  }
  renderExamChip();

  // --- Topic filter (tema) ---------------------------------------------------
  const temaButtons = Array.from(
    document.querySelectorAll<HTMLButtonElement>('[data-tema-filter]'),
  );
  let temaFilter = 'all';

  function applyTemaFilter(): void {
    document.querySelectorAll<HTMLElement>('[data-tq]').forEach((q) => {
      q.hidden = temaFilter !== 'all' && q.dataset.tema !== temaFilter;
    });
    document.dispatchEvent(new CustomEvent('practica:filter-changed'));
  }

  // Resets the button states to «Todos» without reapplying visibility — used
  // when «solo mis fallos» or the exam mode take over the `hidden` flag.
  function resetTemaButtons(): void {
    temaFilter = 'all';
    temaButtons.forEach((b) => {
      const on = b.dataset.temaFilter === 'all';
      b.classList.toggle('on', on);
      b.setAttribute('aria-pressed', String(on));
    });
  }

  temaButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      temaFilter = btn.dataset.temaFilter ?? 'all';
      temaButtons.forEach((b) => {
        const on = b === btn;
        b.classList.toggle('on', on);
        b.setAttribute('aria-pressed', String(on));
      });
      // The topic filter shares `hidden` with «solo mis fallos» and the exam
      // mode: selecting a tema takes over, so drop both first.
      if (failedToggle?.checked) {
        failedToggle.checked = false;
        applyFailedFilter();
      }
      if (examActive) exitExam();
      applyTemaFilter();
    });
  });
</script>

<style>
  .ph {
    margin-bottom: 1.8rem;
  }
  .ph-sigla {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    color: #fff;
    background: var(--site-accent);
    border-radius: 7px;
    padding: 0.25rem 0.55rem;
    margin-bottom: 0.6rem;
  }
  .ph h1 {
    font-size: clamp(1.4rem, 3vw, 1.9rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1.15;
  }
  .ph-sub {
    margin-top: 0.5rem;
    color: var(--site-muted);
    font-size: 0.9rem;
  }
  .block {
    margin-top: 2rem;
  }
  .block-h {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 1.1rem;
    font-weight: 800;
    margin-bottom: 0.3rem;
  }
  .block-idx {
    font-size: 0.72rem;
    font-weight: 800;
    color: #fff;
    background: var(--site-ink);
    border-radius: 6px;
    padding: 0.15rem 0.5rem;
  }
  .block-desc {
    color: var(--site-muted);
    font-size: 0.88rem;
    margin-bottom: 1.1rem;
  }
  .test-foot {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: 1.2rem;
  }
  .btn-grade {
    cursor: pointer;
    border: none;
    background: var(--site-accent);
    color: #fff;
    font: inherit;
    font-weight: 700;
    font-size: 0.9rem;
    padding: 0.7rem 1.3rem;
    border-radius: 10px;
  }
  .btn-grade:hover {
    filter: brightness(1.06);
  }
  .btn-reset {
    cursor: pointer;
    background: none;
    color: var(--site-muted);
    border: 1px solid var(--site-line);
    font: inherit;
    font-weight: 600;
    font-size: 0.85rem;
    padding: 0.7rem 1.1rem;
    border-radius: 10px;
  }
  .btn-reset:hover {
    color: var(--site-ink);
    border-color: var(--site-accent);
  }
  .score {
    font-weight: 700;
  }
  .panel-summary {
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 800;
    font-size: 0.9rem;
    color: var(--site-ink);
  }
  .panel-summary::-webkit-details-marker {
    display: none;
  }
  .panel-summary::after {
