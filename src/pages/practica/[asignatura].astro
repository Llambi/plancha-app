---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TestQuestion from '../../components/TestQuestion.astro';
import DesarrolloQuestion from '../../components/DesarrolloQuestion.astro';
import Minimap from '../../components/Minimap.astro';
import { meta } from '../../data/asignaturas';

export async function getStaticPaths() {
  const test = await getCollection('test');
  const desarrollo = await getCollection('desarrollo');
  const guia = await getCollection('guia');
  // Las asignaturas con guía exponen su test como quiz dentro de la guía.
  const guiaCodes = new Set(guia.map((g) => g.data.asignatura));
  const codes = new Set<string>(
    [...test.map((t) => t.data.asignatura), ...desarrollo.map((d) => d.data.asignatura)].filter(
      (c) => !guiaCodes.has(c),
    ),
  );

  const byNum = (a: string, b: string) => a.localeCompare(b, 'es', { numeric: true });

  return Array.from(codes).map((code) => {
    const tests = test
      .filter((t) => t.data.asignatura === code)
      .sort((a, b) => byNum(a.data.id, b.data.id));
    const devs = desarrollo
      .filter((d) => d.data.asignatura === code)
      .sort((a, b) => a.data.orden - b.data.orden);
    return { params: { asignatura: code }, props: { code, tests, devs } };
  });
}

const { code, tests, devs } = Astro.props;
const m = meta(code);

// Renderiza el cuerpo (respuesta modelo) de cada desarrollo.
const devsRendered = await Promise.all(
  devs.map(async (d) => ({ data: d.data, Content: (await render(d)).Content })),
);
---

<BaseLayout
  title={`${m.sigla} · Práctica de examen`}
  accent={m.accent}
  docTitle={`${m.sigla} · Práctica`}
  home={true}
>
  <header class="ph">
    <span class="ph-sigla">{m.sigla}</span>
    <h1>{m.nombre}</h1>
    <p class="ph-sub">
      {tests.length > 0 && <span>{tests.length} preguntas tipo test</span>}
      {tests.length > 0 && devs.length > 0 && <span> · </span>}
      {devs.length > 0 && <span>{devs.length} de desarrollo</span>}
    </p>
  </header>

  {
    tests.length > 0 && (
      <section class="block" aria-labelledby="h-test" data-practica={code}>
        <h2 class="block-h" id="h-test">
          <span class="block-idx">I</span> Preguntas tipo test
        </h2>
        <p class="block-desc">
          Marca una opción (o varias en las de selección múltiple) y pulsa «Corregir». ¿Solo quieres
          comprobar una? Pulsa «Ver respuesta» en esa pregunta: la solución se muestra unos segundos
          y se oculta sola.
        </p>

        <div class="stats" data-stats>
          <p class="stats-summary" data-stats-summary />
          <div class="stats-actions">
            <label class="stats-toggle">
              <input type="checkbox" data-failed-toggle /> Solo mis fallos
            </label>
            <button class="btn-reset" type="button" data-stats-reset>
              Reiniciar estadísticas
            </button>
          </div>
        </div>

        <div class="exam" data-exam-panel>
          <p class="exam-title">Modo examen</p>
          <div class="exam-opts">
            <label class="exam-opt">
              <input type="checkbox" data-exam-shuffle /> Barajar preguntas
            </label>
            <label class="exam-opt">
              <input type="checkbox" data-exam-subset-toggle /> Subconjunto de
              <input
                type="number"
                min="1"
                max={tests.length}
                value={tests.length}
                data-exam-subset-n
                disabled
              />{' '}
              preguntas
            </label>
            <label class="exam-opt">
              <input type="checkbox" data-exam-timed /> Cronometrado, minutos:
              <input type="number" min="1" value="20" data-exam-minutes disabled />
            </label>
          </div>
          <div class="exam-actions">
            <button class="btn-grade" type="button" data-exam-start>
              {' '}
              Empezar simulacro{' '}
            </button>
            <button class="btn-reset" type="button" data-exam-exit hidden>
              Salir de modo examen
            </button>
            <span class="exam-timer" role="status" aria-live="polite" data-exam-timer />
          </div>
        </div>

        {tests.map((q, i) => (
          <TestQuestion
            id={q.data.id}
            type={q.data.type}
            question={q.data.question}
            options={q.data.options}
            correct={q.data.correct}
            explicacion={q.data.explicacion}
            tema={q.data.tema}
            num={i + 1}
          />
        ))}
        <div class="test-foot">
          <button class="btn-grade" type="button" data-grade-trigger>
            Corregir test
          </button>
          <button class="btn-reset" type="button" data-reset-trigger>
            Reiniciar progreso
          </button>
          <span class="score" role="status" aria-live="polite" />
        </div>
      </section>
    )
  }

  {
    devsRendered.length > 0 && (
      <section class="block" aria-labelledby="h-dev">
        <h2 class="block-h" id="h-dev">
          <span class="block-idx">{tests.length > 0 ? 'II' : 'I'}</span> Preguntas de desarrollo
        </h2>
        <p class="block-desc">Escribe tu respuesta y contrástala con la respuesta modelo.</p>
        {devsRendered.map((d, i) => (
          <DesarrolloQuestion
            id={d.data.id}
            enunciado={d.data.enunciado}
            titulo={d.data.titulo}
            kind={d.data.kind}
            tema={d.data.tema}
            num={i + 1}
          >
            <d.Content />
          </DesarrolloQuestion>
        ))}
      </section>
    )
  }

  {
    (tests.length > 0 || devsRendered.length > 0) && (
      <Minimap scope={`practica-${code}`} kind="practica" />
    )
  }
</BaseLayout>

<script>
  import { statsKeyFor, parseStats, summarize, failedIds } from '../../lib/practica-stats';

  document.addEventListener('tq:graded', (e) => {
    const { score, total } = (e as CustomEvent).detail;
    const el = document.querySelector('.score');
    if (el) el.textContent = `Aciertos: ${score} / ${total}`;
  });

  // --- Stats summary panel (per asignatura) ---------------------------------
  const asignatura = document.querySelector('[data-practica]')?.getAttribute('data-practica') ?? '';
  const summaryEl = document.querySelector<HTMLElement>('[data-stats-summary]');

  function safeGet(key: string): string | null {
    try {
      return localStorage.getItem(key);
    } catch {
      return null;
    }
  }
  function safeRemove(key: string): void {
    try {
      localStorage.removeItem(key);
    } catch {
      /* no-op */
    }
  }

  const pct = (x: number) => `${Math.round(x * 100)}%`;

  // Maps a question id ("q-<id>") to its displayed number, read from the DOM.
  function questionNum(id: string): string {
    return document.getElementById(id)?.querySelector('.tq-num')?.textContent?.trim() ?? '?';
  }

  function renderStats(): void {
    if (!asignatura || !summaryEl) return;
    const total = document.querySelectorAll('[data-tq]').length;
    const state = parseStats(safeGet(statsKeyFor(asignatura)));
    const sum = state && summarize(state);
    if (!sum || sum.answered === 0) {
      summaryEl.textContent =
        'Aún no has corregido preguntas. Corrige el test para ver tus estadísticas.';
      return;
    }
    const top = sum.mostFailed
      .slice(0, 5)
      .map((m) => `<a href="#${m.id}">${questionNum(m.id)}</a> (×${m.wrong})`)
      .join(' · ');
    summaryEl.innerHTML =
      `<strong>Respondidas:</strong> ${sum.answered} de ${total} · ` +
      `<strong>Acierto último intento:</strong> ${pct(sum.accuracyLast)} · ` +
      `<strong>Acumulado:</strong> ${pct(sum.accuracyAll)}` +
      (top ? `<br /><strong>Más falladas:</strong> ${top}` : '');
  }

  // «Solo mis fallos»: show only questions whose last attempt was wrong.
  const failedToggle = document.querySelector<HTMLInputElement>('[data-failed-toggle]');

  function applyFailedFilter(): void {
    if (!asignatura) return;
    const on = failedToggle?.checked ?? false;
    const state = parseStats(safeGet(statsKeyFor(asignatura)));
    const failed = new Set(state ? failedIds(state) : []);
    document.querySelectorAll<HTMLElement>('[data-tq]').forEach((q) => {
      q.hidden = on && !failed.has(q.id);
    });
    document.dispatchEvent(new CustomEvent('practica:filter-changed'));
  }

  failedToggle?.addEventListener('change', applyFailedFilter);

  // Reset stats only (independent of the answers progress reset of #8).
  document.querySelector('[data-stats-reset]')?.addEventListener('click', () => {
    if (asignatura) safeRemove(statsKeyFor(asignatura));
    if (failedToggle) failedToggle.checked = false;
    applyFailedFilter();
    renderStats();
  });

  document.addEventListener('practica:stats-updated', renderStats);
  renderStats();

  // --- Exam mode (shuffle / N-question subset / timed simulacro) ------------
  const examPanel = document.querySelector<HTMLElement>('[data-exam-panel]');
  const examStartBtn = document.querySelector<HTMLButtonElement>('[data-exam-start]');
  const examExitBtn = document.querySelector<HTMLButtonElement>('[data-exam-exit]');
  const testSection = document.querySelector<HTMLElement>('[data-practica]');

  // Enable a paired number input only while its checkbox is checked.
  function wireToggle(checkboxSel: string, inputSel: string): void {
    const checkbox = document.querySelector<HTMLInputElement>(checkboxSel);
    const input = document.querySelector<HTMLInputElement>(inputSel);
    if (!checkbox || !input) return;
    checkbox.addEventListener('change', () => {
      input.disabled = !checkbox.checked;
    });
  }
  wireToggle('[data-exam-subset-toggle]', '[data-exam-subset-n]');
  wireToggle('[data-exam-timed]', '[data-exam-minutes]');

  if (examPanel && examStartBtn && examExitBtn && testSection) {
    // Original order/visibility of the questions, captured once so «Salir de
    // modo examen» can restore it exactly regardless of what the simulacro did.
    const originalOrder = Array.from(testSection.querySelectorAll<HTMLElement>('[data-tq]'));

    function startExam(): void {
      examStartBtn!.hidden = true;
      examExitBtn!.hidden = false;
    }

    function exitExam(): void {
      const container = originalOrder[0]?.parentElement;
      if (container) {
        for (const q of originalOrder) {
          q.hidden = false;
          container.appendChild(q);
        }
      }
      document.dispatchEvent(new CustomEvent('practica:filter-changed'));
      examStartBtn!.hidden = false;
      examExitBtn!.hidden = true;
    }

    examStartBtn.addEventListener('click', startExam);
    examExitBtn.addEventListener('click', exitExam);
  }
</script>

<style>
  .ph {
    margin-bottom: 1.8rem;
  }
  .ph-sigla {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    color: #fff;
    background: var(--site-accent);
    border-radius: 7px;
    padding: 0.25rem 0.55rem;
    margin-bottom: 0.6rem;
  }
  .ph h1 {
    font-size: clamp(1.4rem, 3vw, 1.9rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1.15;
  }
  .ph-sub {
    margin-top: 0.5rem;
    color: var(--site-muted);
    font-size: 0.9rem;
  }
  .block {
    margin-top: 2rem;
  }
  .block-h {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 1.1rem;
    font-weight: 800;
    margin-bottom: 0.3rem;
  }
  .block-idx {
    font-size: 0.72rem;
    font-weight: 800;
    color: #fff;
    background: var(--site-ink);
    border-radius: 6px;
    padding: 0.15rem 0.5rem;
  }
  .block-desc {
    color: var(--site-muted);
    font-size: 0.88rem;
    margin-bottom: 1.1rem;
  }
  .test-foot {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: 1.2rem;
  }
  .btn-grade {
    cursor: pointer;
    border: none;
    background: var(--site-accent);
    color: #fff;
    font: inherit;
    font-weight: 700;
    font-size: 0.9rem;
    padding: 0.7rem 1.3rem;
    border-radius: 10px;
  }
  .btn-grade:hover {
    filter: brightness(1.06);
  }
  .btn-reset {
    cursor: pointer;
    background: none;
    color: var(--site-muted);
    border: 1px solid var(--site-line);
    font: inherit;
    font-weight: 600;
    font-size: 0.85rem;
    padding: 0.7rem 1.1rem;
    border-radius: 10px;
  }
  .btn-reset:hover {
    color: var(--site-ink);
    border-color: var(--site-accent);
  }
  .score {
    font-weight: 700;
  }
  .stats {
    margin-bottom: 1.4rem;
    padding: 0.85rem 1rem;
    border: 1px solid var(--site-line);
    border-radius: 12px;
    background: var(--site-surface-2);
  }
  .stats-summary {
    font-size: 0.88rem;
    line-height: 1.7;
    color: var(--site-ink);
  }
  .stats-summary a {
    color: color-mix(in srgb, var(--site-accent) 74%, var(--site-ink));
    font-weight: 700;
  }
  .stats-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
    margin-top: 0.7rem;
  }
  .stats-toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    color: var(--site-muted);
  }
  .stats-toggle input {
    accent-color: var(--site-accent);
    width: 1rem;
    height: 1rem;
  }
  .exam {
    margin-bottom: 1.4rem;
    padding: 0.85rem 1rem;
    border: 1px solid var(--site-line);
    border-radius: 12px;
    background: var(--site-surface-2);
  }
  .exam-title {
    font-weight: 800;
    font-size: 0.9rem;
    margin-bottom: 0.6rem;
  }
  .exam-opts {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .exam-opt {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--site-muted);
  }
  .exam-opt input[type='checkbox'] {
    accent-color: var(--site-accent);
    width: 1rem;
    height: 1rem;
  }
  .exam-opt input[type='number'] {
    width: 4.2rem;
    font: inherit;
    padding: 0.2rem 0.4rem;
    border: 1px solid var(--site-line);
    border-radius: 6px;
  }
  .exam-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: 0.85rem;
  }
  .exam-timer {
    font-weight: 700;
  }
</style>
