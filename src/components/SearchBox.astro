---
/**
 * SearchBox — buscador global de la topbar.
 * Patrón ARIA combobox: input + listbox de resultados dinámicos debajo. Carga el
 * índice (`search-index.json`) de forma perezosa al primer foco y busca con
 * Fuse.js (`src/lib/search.ts`). Teclado: ↑/↓ mueven el foco, Enter abre el ítem
 * activo (deep-link) y, sin selección, va a `/buscar`; Esc cierra. En móvil se
 * colapsa en un icono de lupa que despliega el campo.
 */
import { BASE } from '../data/site';

const indexUrl = `${BASE}/search-index.json`;
const buscarUrl = `${BASE}/buscar`;
---

<div class="searchbox" data-searchbox data-index={indexUrl} data-buscar={buscarUrl}>
  <button
    class="sb-toggle"
    type="button"
    aria-label="Abrir buscador"
    aria-expanded="false"
    data-sb-toggle
  >
    <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" focusable="false">
      <path
        d="M21 21l-4.3-4.3M11 18a7 7 0 100-14 7 7 0 000 14z"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"></path>
    </svg>
  </button>

  <form class="sb-form" role="search" data-sb-form>
    <span class="sb-ic" aria-hidden="true">
      <svg viewBox="0 0 24 24" width="16" height="16" focusable="false">
        <path
          d="M21 21l-4.3-4.3M11 18a7 7 0 100-14 7 7 0 000 14z"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"></path>
      </svg>
    </span>
    <input
      class="sb-input"
      type="search"
      role="combobox"
      aria-expanded="false"
      aria-controls="sb-listbox"
      aria-autocomplete="list"
      aria-label="Buscar en PlanchaAPP"
      placeholder="Buscar…"
      autocomplete="off"
      enterkeyhint="search"
      data-sb-input
    />

    <div class="sb-panel" hidden data-sb-panel>
      <ul class="sb-list" id="sb-listbox" role="listbox" aria-label="Resultados" data-sb-list></ul>
      <p class="sb-empty" hidden data-sb-empty>Sin resultados para tu búsqueda.</p>
      <button class="sb-all" type="button" hidden data-sb-all>Ver todos los resultados →</button>
      <div class="sb-legend" aria-hidden="true">
        <span><kbd>↑</kbd><kbd>↓</kbd> moverse</span>
        <span><kbd>↵</kbd> abrir</span>
        <span><kbd>↵</kbd> sin selección: ver todos</span>
      </div>
    </div>
  </form>
</div>

<style>
  .searchbox {
    position: relative;
    display: flex;
    align-items: center;
  }

  /* Botón lupa: solo visible en móvil. */
  .sb-toggle {
    display: none;
    cursor: pointer;
    background: transparent;
    color: inherit;
    border: 1px solid var(--site-topbar-line);
    border-radius: 9px;
    width: 40px;
    height: 34px;
    align-items: center;
    justify-content: center;
  }
  .sb-toggle:hover {
    background: rgba(255, 255, 255, 0.12);
  }

  .sb-form {
    position: relative;
    display: flex;
    align-items: center;
  }
  .sb-ic {
    position: absolute;
    left: 10px;
    display: inline-flex;
    color: var(--site-topbar-ink);
    opacity: 0.65;
    pointer-events: none;
  }
  .sb-input {
    font: inherit;
    font-size: 13px;
    color: var(--site-topbar-ink);
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid var(--site-topbar-line);
    border-radius: 9px;
    padding: 7px 10px 7px 32px;
    width: 230px;
    max-width: 40vw;
    transition:
      width 0.16s ease,
      background 0.15s;
  }
  .sb-input::placeholder {
    color: var(--site-topbar-ink);
    opacity: 0.6;
  }
  .sb-input:focus {
    outline: none;
    background: rgba(255, 255, 255, 0.16);
    border-color: var(--site-accent);
    width: 280px;
  }
  /* Oculta la cruz nativa del type=search para un look consistente. */
  .sb-input::-webkit-search-decoration,
  .sb-input::-webkit-search-cancel-button {
    -webkit-appearance: none;
  }

  /* Panel de resultados, anclado bajo el input. */
  .sb-panel {
    position: absolute;
    top: calc(100% + 8px);
    left: 0;
    width: min(420px, 92vw);
    background: var(--site-surface);
    color: var(--site-ink);
    border: 1px solid var(--site-line);
    border-radius: 12px;
    box-shadow: var(--site-shadow-lg);
    padding: 6px;
    z-index: 1200;
    overflow: hidden;
  }
  .sb-list {
    list-style: none;
    margin: 0;
    padding: 0;
    max-height: min(56vh, 420px);
    overflow-y: auto;
  }
  .sb-empty {
    padding: 14px 10px;
    color: var(--site-muted);
    font-size: 0.85rem;
    text-align: center;
  }
  .sb-all {
    display: block;
    width: 100%;
    text-align: left;
    font: inherit;
    font-size: 0.8rem;
    font-weight: 600;
    cursor: pointer;
    color: var(--site-accent);
    background: transparent;
    border: none;
    border-top: 1px solid var(--site-line);
    padding: 9px 10px;
    margin-top: 4px;
  }
  .sb-all:hover {
    text-decoration: underline;
  }
  .sb-legend {
    display: flex;
    flex-wrap: wrap;
    gap: 6px 12px;
    padding: 8px 10px 4px;
    margin-top: 2px;
    border-top: 1px solid var(--site-line);
    font-size: 0.68rem;
    color: var(--site-muted);
  }
  .sb-legend span {
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }
  .sb-legend kbd {
    font-family: var(--site-sans);
    font-size: 0.66rem;
    line-height: 1;
    min-width: 1.1em;
    text-align: center;
    padding: 2px 4px;
    border: 1px solid var(--site-line);
    border-bottom-width: 2px;
    border-radius: 5px;
    background: var(--site-surface-2);
    color: var(--site-ink);
  }

  /* ===== Móvil/tablet: colapsa en icono que despliega el campo ===== */
  @media (max-width: 820px) {
    .sb-toggle {
      display: inline-flex;
    }
    .sb-form {
      display: none;
    }
    .searchbox.sb-open .sb-form {
      display: flex;
      position: fixed;
      left: 10px;
      right: 10px;
      top: 8px;
      z-index: 1300;
    }
    .searchbox.sb-open .sb-input {
      width: 100%;
      max-width: none;
      background: var(--site-surface);
      color: var(--site-ink);
      border-color: var(--site-line);
    }
    .searchbox.sb-open .sb-ic {
      color: var(--site-ink);
    }
    .searchbox.sb-open .sb-input::placeholder {
      color: var(--site-muted);
    }
    .sb-panel {
      width: 100%;
      left: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .sb-input {
      transition: none;
    }
  }
</style>

<!--
  Las opciones del listbox se crean dinámicamente por JS, así que NO reciben el
  atributo de scope de Astro: sus estilos van en un bloque global, acotado bajo
  `.searchbox` para no filtrarse al resto del sitio.
-->
<style is:global>
  .searchbox .sb-opt {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 9px;
    border-radius: 9px;
    cursor: pointer;
    scroll-margin: 6px;
  }
  .searchbox .sb-opt[aria-selected='true'],
  .searchbox .sb-opt:hover {
    background: var(--site-surface-2);
  }
  .searchbox .sb-opt[aria-selected='true'] {
    outline: 2px solid var(--site-accent);
    outline-offset: -2px;
  }
  .searchbox .sb-badge {
    flex: none;
    width: 30px;
    height: 30px;
    border-radius: 8px;
    display: grid;
    place-items: center;
    color: #fff;
    font-weight: 800;
    font-size: 0.6rem;
    letter-spacing: 0.02em;
    background: var(--c, var(--site-accent));
  }
  .searchbox .sb-opt-body {
    display: flex;
    flex-direction: column;
    min-width: 0;
    flex: 1;
  }
  .searchbox .sb-opt-meta {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.64rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--site-muted);
    margin-bottom: 1px;
  }
  .searchbox .sb-opt-tipo {
    color: color-mix(in srgb, var(--c, var(--site-accent)) 70%, var(--site-ink));
  }
  .searchbox .sb-opt-title {
    font-size: 0.86rem;
    line-height: 1.3;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
</style>

<script>
  import { createSearcher, type SearchRecord, type Searcher } from '../lib/search';

  const root = document.querySelector<HTMLElement>('[data-searchbox]');
  if (root) {
    const form = root.querySelector<HTMLFormElement>('[data-sb-form]')!;
    const input = root.querySelector<HTMLInputElement>('[data-sb-input]')!;
    const panel = root.querySelector<HTMLElement>('[data-sb-panel]')!;
    const list = root.querySelector<HTMLUListElement>('[data-sb-list]')!;
    const empty = root.querySelector<HTMLElement>('[data-sb-empty]')!;
    const allBtn = root.querySelector<HTMLButtonElement>('[data-sb-all]')!;
    const toggle = root.querySelector<HTMLButtonElement>('[data-sb-toggle]')!;
    const indexUrl = root.dataset.index!;
    const buscarUrl = root.dataset.buscar!;

    const LIMIT = 7;
    let searcher: Searcher | null = null;
    let loading: Promise<void> | null = null;
    let results: SearchRecord[] = [];
    let active = -1;

    function loadIndex(): Promise<void> {
      if (loading) return loading;
      loading = fetch(indexUrl)
        .then((r) => r.json())
        .then((records: SearchRecord[]) => {
          searcher = createSearcher(records);
        })
        .catch(() => {
          /* sin índice: el buscador queda inerte, no rompe la página */
        });
      return loading;
    }

    function goto(href: string) {
      window.location.href = href;
    }

    function gotoAll() {
      const q = input.value.trim();
      goto(`${buscarUrl}?q=${encodeURIComponent(q)}`);
    }

    function open() {
      panel.hidden = false;
      input.setAttribute('aria-expanded', 'true');
    }
    function close() {
      panel.hidden = true;
      input.setAttribute('aria-expanded', 'false');
      input.removeAttribute('aria-activedescendant');
      active = -1;
    }
    // En móvil/tablet, recoge el campo desplegado y vuelve a dejar solo la lupa.
    const collapseMobile = () => {
      if (root.classList.contains('sb-open')) {
        root.classList.remove('sb-open');
        toggle.setAttribute('aria-expanded', 'false');
      }
    };

    function render() {
      list.innerHTML = '';
      results.forEach((r, i) => {
        const li = document.createElement('li');
        li.className = 'sb-opt';
        li.id = `sb-opt-${i}`;
        li.setAttribute('role', 'option');
        li.setAttribute('aria-selected', 'false');
        li.style.setProperty('--c', r.accent);
        li.innerHTML =
          `<span class="sb-badge">${esc(r.sigla)}</span>` +
          `<span class="sb-opt-body">` +
          `<span class="sb-opt-meta"><span>${esc(r.asignaturaNombre)}</span>` +
          `<span class="sb-opt-tipo">${esc(r.tipoLabel)}</span></span>` +
          `<span class="sb-opt-title">${esc(r.titulo)}</span></span>`;
        li.addEventListener('mousedown', (e) => {
          e.preventDefault(); // evita el blur antes de navegar
          goto(r.url);
        });
        li.addEventListener('mousemove', () => setActive(i));
        list.appendChild(li);
      });
      const has = results.length > 0;
      empty.hidden = has || input.value.trim().length === 0;
      allBtn.hidden = !has;
      if (has) allBtn.textContent = `Ver todos los resultados →`;
      open();
    }

    function setActive(i: number) {
      const items = Array.from(list.children) as HTMLElement[];
      if (active >= 0 && items[active]) items[active].setAttribute('aria-selected', 'false');
      active = i;
      if (i >= 0 && items[i]) {
        items[i].setAttribute('aria-selected', 'true');
        items[i].scrollIntoView({ block: 'nearest' });
        input.setAttribute('aria-activedescendant', items[i].id);
      } else {
        input.removeAttribute('aria-activedescendant');
      }
    }

    function esc(s: string): string {
      return s
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;');
    }

    function runSearch() {
      const q = input.value.trim();
      if (!q) {
        close();
        return;
      }
      // El índice carga de forma perezosa: si aún no está, reintenta al terminar.
      if (!searcher) {
        loadIndex().then(runSearch);
        return;
      }
      results = searcher.search(q, LIMIT);
      render();
      setActive(-1);
    }

    let debounce: ReturnType<typeof setTimeout>;
    function onInput() {
      clearTimeout(debounce);
      debounce = setTimeout(runSearch, 120);
    }

    input.addEventListener('focus', () => void loadIndex());
    input.addEventListener('input', onInput);

    input.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowDown') {
        e.preventDefault();
        if (panel.hidden) return;
        setActive(Math.min(active + 1, results.length - 1));
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        if (panel.hidden) return;
        setActive(Math.max(active - 1, -1));
      } else if (e.key === 'Enter') {
        e.preventDefault();
        if (active >= 0 && results[active]) goto(results[active].url);
        else gotoAll();
      } else if (e.key === 'Escape') {
        close();
        collapseMobile();
      }
    });

    // Enviar el formulario (Enter) sin selección → página de resultados.
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      if (active < 0) gotoAll();
    });

    allBtn.addEventListener('mousedown', (e) => {
      e.preventDefault();
      gotoAll();
    });

    // Cerrar (y recoger en móvil) al hacer click/interactuar fuera.
    document.addEventListener('click', (e) => {
      if (!root.contains(e.target as Node)) {
        close();
        collapseMobile();
      }
    });

    // Al perder el foco (tab fuera, tocar otra cosa): recoge el campo en móvil.
    input.addEventListener('blur', () => {
      setTimeout(() => {
        if (!root.contains(document.activeElement)) {
          close();
          collapseMobile();
        }
      }, 120);
    });

    // Móvil: desplegar/ocultar el campo con la lupa.
    toggle.addEventListener('click', () => {
      const willOpen = !root.classList.contains('sb-open');
      root.classList.toggle('sb-open', willOpen);
      toggle.setAttribute('aria-expanded', String(willOpen));
      if (willOpen) {
        loadIndex();
        requestAnimationFrame(() => input.focus());
      } else {
        close();
      }
    });
  }
</script>
