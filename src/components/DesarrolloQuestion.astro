---
/**
 * DesarrolloQuestion — pregunta de desarrollo (o ejercicio práctico).
 * Renderiza el enunciado VERBATIM (`set:html`), un textarea para la respuesta
 * del usuario y un botón que revela la respuesta modelo (slot por defecto, que
 * la página rellena con el <Content /> renderizado de la colección).
 */
interface Props {
  id: string;
  enunciado: string;
  titulo?: string;
  kind?: 'desarrollo' | 'practico';
  tema?: string;
  num?: number;
}
const { id, enunciado, titulo, kind = 'desarrollo', tema, num } = Astro.props;
---

<article class="dq" data-dq>
  <header class="dq-head">
    {num != null && <span class="dq-num">{num}</span>}
    <div class="dq-headtext">
      {
        (titulo || kind === 'practico') && (
          <span class="dq-kind">
            {kind === 'practico' ? 'Ejercicio práctico' : 'Desarrollo'}
            {tema && ` · ${tema}`}
          </span>
        )
      }
      {titulo && <h3 class="dq-titulo">{titulo}</h3>}
    </div>
  </header>

  <p class="dq-enun" set:html={enunciado} />

  <textarea class="dq-text" placeholder="Escribe aquí tu respuesta…" aria-label="Tu respuesta"
  ></textarea>

  <button class="dq-reveal" type="button" aria-expanded="false"> Ver respuesta modelo </button>

  <div class="dq-model" hidden>
    <h4 class="dq-model-h">Respuesta modelo</h4>
    <slot />
  </div>
</article>

<style>
  .dq {
    border: 1px solid var(--site-line);
    border-radius: var(--site-radius);
    background: var(--site-surface);
    box-shadow: var(--site-shadow);
    padding: 1.1rem 1.2rem 1.2rem;
    margin: 0 0 1rem;
  }
  .dq-head {
    display: flex;
    gap: 0.7rem;
    align-items: flex-start;
    margin-bottom: 0.6rem;
  }
  .dq-num {
    flex: none;
    width: 1.7rem;
    height: 1.7rem;
    border-radius: 8px;
    display: grid;
    place-items: center;
    font-size: 0.8rem;
    font-weight: 700;
    background: var(--site-accent);
    color: #fff;
  }
  .dq-kind {
    display: block;
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--site-accent);
  }
  .dq-titulo {
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.3;
    margin-top: 0.1rem;
  }
  .dq-enun {
    line-height: 1.55;
    margin-bottom: 0.8rem;
  }
  .dq-text {
    width: 100%;
    min-height: 7rem;
    resize: vertical;
    font: inherit;
    font-size: 0.92rem;
    line-height: 1.5;
    padding: 0.7rem 0.8rem;
    border: 1px solid var(--site-line);
    border-radius: 10px;
    background: var(--site-surface-2);
    color: var(--site-ink);
  }
  .dq-text:focus {
    outline: none;
    border-color: var(--site-accent);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--site-accent) 18%, transparent);
  }
  .dq-reveal {
    margin-top: 0.7rem;
    cursor: pointer;
    border: 1px solid var(--site-line);
    background: var(--site-surface-2);
    color: var(--site-accent);
    font: inherit;
    font-weight: 600;
    font-size: 0.85rem;
    padding: 0.55rem 1rem;
    border-radius: 9px;
    transition: border-color 0.15s;
  }
  .dq-reveal:hover {
    border-color: var(--site-accent);
  }
  .dq-model {
    margin-top: 0.9rem;
    padding: 0.9rem 1rem;
    border-left: 3px solid var(--site-accent);
    background: var(--site-surface-2);
    border-radius: 0 10px 10px 0;
  }
  .dq-model-h {
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--site-muted);
    margin-bottom: 0.5rem;
  }
  /* contenido del modelo (markdown renderizado / HTML verbatim) */
  .dq-model :global(ul) {
    margin: 0 0 0.6rem 1.1rem;
  }
  .dq-model :global(li) {
    margin-bottom: 0.4rem;
    line-height: 1.5;
  }
  .dq-model :global(p) {
    margin-bottom: 0.6rem;
    line-height: 1.55;
  }
  .dq-model :global(pre) {
    background: var(--site-bg);
    border: 1px solid var(--site-line);
    border-radius: 8px;
    padding: 0.6rem 0.8rem;
    overflow-x: auto;
    font-size: 0.82rem;
    margin-bottom: 0.6rem;
  }
  .dq-model :global(code),
  .dq-model :global(kbd) {
    font-family: ui-monospace, 'SFMono-Regular', Menlo, monospace;
    font-size: 0.85em;
  }
  .dq-model :global(.src) {
    margin-top: 0.4rem;
  }
  .dq-model :global(.tag) {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--site-accent);
    background: color-mix(in srgb, var(--site-accent) 12%, transparent);
    border-radius: 6px;
    padding: 0.15rem 0.5rem;
    margin-right: 0.35rem;
  }
</style>

<script>
  document.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.dq-reveal');
    if (!btn) return;
    const card = btn.closest('[data-dq]');
    const model = card?.querySelector('.dq-model');
    if (!model) return;
    const isHidden = model.hasAttribute('hidden');
    if (isHidden) model.removeAttribute('hidden');
    else model.setAttribute('hidden', '');
    btn.setAttribute('aria-expanded', String(isHidden));
    btn.textContent = isHidden ? 'Ocultar respuesta modelo' : 'Ver respuesta modelo';
  });
</script>
