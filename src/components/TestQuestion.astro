---
/**
 * TestQuestion — una pregunta de test (single o multi).
 * El contenido (question, options, explicacion) se renderiza VERBATIM con
 * `set:html` para respetar el HTML inline del origen. No transforma texto.
 *
 * La corrección la dispara un botón con [data-grade-trigger] en la página;
 * el script (incluido una sola vez por Astro) marca aciertos/fallos, revela
 * la explicación y emite un evento `tq:graded` con la puntuación.
 */
import PinButton from './PinButton.astro';
import { stripTags, truncateLabel } from '../lib/minimap';

interface Props {
  id: string;
  type: 'single' | 'multi';
  question: string;
  options: string[];
  correct: number[];
  explicacion?: string;
  tema?: string;
  num?: number;
  apariciones?: number;
}

const { id, type, question, options, correct, explicacion, tema, num, apariciones } = Astro.props;

const LETTERS = ['A', 'B', 'C', 'D', 'E', 'F', 'G', 'H'];
const inputType = type === 'single' ? 'radio' : 'checkbox';
const mmLabel = truncateLabel(`${num ?? ''} · ${stripTags(question)}`.trim());
---

<fieldset
  id={`q-${id}`}
  class="tq mm-anchor"
  data-tq
  data-correct={JSON.stringify(correct)}
  data-type={type}
  data-mm-type="test"
  data-mm-level="0"
  data-mm-label={mmLabel}
>
  <legend class="tq-head">
    {num != null && <span class="tq-num">{num}</span>}
    <span class="tq-q">
      <span>{question}</span>
      {type === 'multi' && <span class="tq-multi">selección múltiple</span>}
      {
        apariciones != null && apariciones > 1 && (
          <span class="tq-aparic" title="Veces que apareció en exámenes anteriores">
            ×{apariciones} en exámenes
          </span>
        )
      }
    </span>
    <PinButton label="Fijar pregunta" />
  </legend>

  <div class="tq-opts">
    {
      options.map((opt, i) => (
        <label class="tq-opt">
          <input type={inputType} name={`q-${id}`} value={i} />
          <span class="tq-letter">{LETTERS[i] ?? i + 1}</span>
          <span class="tq-opt-text">{opt}</span>
        </label>
      ))
    }
  </div>

  <div class="tq-actions">
    <button class="tq-reveal" type="button" data-reveal-trigger aria-pressed="false">
      Ver respuesta
    </button>
  </div>

  {
    explicacion && (
      <div class="tq-exp" hidden>
        <strong>Explicación.</strong> <span>{explicacion}</span>
      </div>
    )
  }
  {tema && <p class="tq-tema">{tema}</p>}
</fieldset>

<style>
  .tq {
    border: 1px solid var(--site-line);
    border-radius: var(--site-radius);
    background: var(--site-surface);
    box-shadow: var(--site-shadow);
    padding: 1.1rem 1.2rem 1.2rem;
    margin: 0 0 1rem;
    scroll-margin-top: 72px; /* deep-link: que la topbar sticky no tape la pregunta */
  }
  /* Resalta brevemente la pregunta al llegar por deep-link (#q-…). */
  .tq:target {
    border-color: var(--site-accent);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--site-accent) 30%, transparent);
  }
  .tq-head {
    display: flex;
    gap: 0.7rem;
    align-items: flex-start;
    padding: 0;
    margin-bottom: 0.9rem;
  }
  .tq-num {
    flex: none;
    width: 1.7rem;
    height: 1.7rem;
    border-radius: 8px;
    display: grid;
    place-items: center;
    font-size: 0.8rem;
    font-weight: 700;
    background: var(--site-accent);
    color: #fff;
  }
  .tq-q {
    font-weight: 600;
    line-height: 1.45;
    flex: 1;
    min-width: 0;
  }
  .tq-multi {
    display: inline-block;
    margin-left: 0.4rem;
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--site-accent);
    vertical-align: middle;
  }
  .tq-aparic {
    display: inline-block;
    margin-left: 0.4rem;
    font-size: 0.66rem;
    font-weight: 700;
    color: var(--site-muted);
    background: var(--site-surface-2);
    border: 1px solid var(--site-line);
    border-radius: 999px;
    padding: 0.05rem 0.45rem;
    vertical-align: middle;
  }
  .tq-opts {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .tq-opt {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.6rem 0.75rem;
    border: 1px solid var(--site-line);
    border-radius: 10px;
    cursor: pointer;
    background: var(--site-surface-2);
    transition:
      border-color 0.15s,
      background 0.15s;
  }
  .tq-opt:hover {
    border-color: var(--site-accent);
  }
  .tq-opt input {
    accent-color: var(--site-accent);
    width: 1.05rem;
    height: 1.05rem;
    flex: none;
  }
  .tq-letter {
    flex: none;
    font-weight: 700;
    font-size: 0.8rem;
    color: var(--site-muted);
    width: 1.1rem;
  }
  .tq-opt-text {
    line-height: 1.4;
  }

  /* Estados tras corregir */
  .tq.graded .tq-opt {
    cursor: default;
  }
  .tq-opt.correct {
    border-color: var(--site-ok);
    background: var(--site-ok-soft);
  }
  .tq-opt.correct .tq-letter {
    color: var(--site-ok);
  }
  .tq-opt.incorrect {
    border-color: var(--site-bad);
    background: var(--site-bad-soft);
  }
  .tq-opt.incorrect .tq-letter {
    color: var(--site-bad);
  }

  /* Temporary per-question reveal (the «Ver respuesta» button) */
  .tq-actions {
    margin-top: 0.85rem;
  }
  .tq-reveal {
    font: inherit;
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--site-accent);
    background: none;
    border: 1px solid var(--site-line);
    border-radius: 999px;
    padding: 0.3rem 0.8rem;
    cursor: pointer;
    transition:
      border-color 0.15s,
      background 0.15s;
  }
  .tq-reveal:hover {
    border-color: var(--site-accent);
    background: var(--site-surface-2);
  }
  /* Once graded in bulk the answer is already visible, so the button is redundant. */
  .tq.graded .tq-reveal {
    display: none;
  }
  .tq-opt.revealed {
    border-color: var(--site-ok);
    background: var(--site-ok-soft);
  }
  .tq-opt.revealed .tq-letter {
    color: var(--site-ok);
  }

  .tq-exp {
    margin-top: 0.85rem;
    padding: 0.7rem 0.85rem;
    border-left: 3px solid var(--site-accent);
    background: var(--site-surface-2);
    border-radius: 0 8px 8px 0;
    font-size: 0.9rem;
    line-height: 1.5;
    color: var(--site-ink);
  }
  .tq-tema {
    margin-top: 0.7rem;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--site-muted);
  }
</style>

<script>
  import { keyFor, serialize, parse, pruneAnswers } from '../lib/practica-progress';
  import { statsKeyFor, serializeStats, parseStats, recordGrading } from '../lib/practica-stats';
  import { isCorrectPick } from '../lib/minimap';

  // Per-question grading outcome (used to feed the stats aggregation).
  type GradeResult = { id: string; answered: boolean; correct: boolean };

  // Corrección delegada (incluido una sola vez por página).
  function gradeAll(): { score: number; total: number; results: GradeResult[] } {
    const qs = Array.from(document.querySelectorAll<HTMLElement>('[data-tq]'));
    let score = 0;
    const results: GradeResult[] = [];
    for (const q of qs) {
      const correct: number[] = JSON.parse(q.dataset.correct || '[]');
      const inputs = Array.from(q.querySelectorAll<HTMLInputElement>('input'));
      const picked = inputs.filter((i) => i.checked).map((i) => Number(i.value));
      const ok = isCorrectPick(correct, picked);
      if (ok) score++;
      results.push({ id: q.id, answered: picked.length > 0, correct: ok });
      q.classList.add('graded');
      inputs.forEach((input) => {
        const idx = Number(input.value);
        const label = input.closest('.tq-opt');
        if (!label) return;
        input.disabled = true;
        if (correct.includes(idx)) label.classList.add('correct');
        else if (input.checked) label.classList.add('incorrect');
      });
      const exp = q.querySelector('.tq-exp');
      if (exp) exp.removeAttribute('hidden');
    }
    return { score, total: qs.length, results };
  }

  // Temporary per-question reveal (the «Ver respuesta» button). Highlights the
  // correct option(s) and shows the explanation; auto-hides after 5 s. A new click
  // restarts the countdown (timers don't stack).
  const REVEAL_MS = 5000;
  const revealTimers = new WeakMap<HTMLElement, number>();

  function hideReveal(q: HTMLElement): void {
    q.querySelectorAll('.tq-opt.revealed').forEach((el) => el.classList.remove('revealed'));
    const exp = q.querySelector('.tq-exp');
    // If it was graded in bulk meanwhile, keep the explanation visible (don't hide it).
    if (exp && !q.classList.contains('graded')) exp.setAttribute('hidden', '');
    q.querySelector('[data-reveal-trigger]')?.setAttribute('aria-pressed', 'false');
  }

  function revealAnswer(q: HTMLElement): void {
    if (q.classList.contains('graded')) return; // already shown permanently
    const correct: number[] = JSON.parse(q.dataset.correct || '[]');
    q.querySelectorAll<HTMLInputElement>('input').forEach((input) => {
      if (correct.includes(Number(input.value)))
        input.closest('.tq-opt')?.classList.add('revealed');
    });
    q.querySelector('.tq-exp')?.removeAttribute('hidden');
    q.querySelector('[data-reveal-trigger]')?.setAttribute('aria-pressed', 'true');
    const prev = revealTimers.get(q);
    if (prev) clearTimeout(prev);
    revealTimers.set(
      q,
      window.setTimeout(() => {
        hideReveal(q);
        revealTimers.delete(q);
      }, REVEAL_MS),
    );
  }

  // --- Progress persistence (localStorage, per asignatura) ------------------
  // The asignatura code is exposed by the practica page on the test section.
  const asignatura = document.querySelector('[data-practica]')?.getAttribute('data-practica') ?? '';

  // localStorage may be unavailable (private mode, quota): degrade silently.
  function safeGet(key: string): string | null {
    try {
      return localStorage.getItem(key);
    } catch {
      return null;
    }
  }
  function safeSet(key: string, value: string): void {
    try {
      localStorage.setItem(key, value);
    } catch {
      /* no-op */
    }
  }
  function safeRemove(key: string): void {
    try {
      localStorage.removeItem(key);
    } catch {
      /* no-op */
    }
  }

  function questionIds(): string[] {
    return Array.from(document.querySelectorAll<HTMLElement>('[data-tq]')).map((q) => q.id);
  }

  function collectAnswers(): Record<string, number[]> {
    const out: Record<string, number[]> = {};
    for (const q of document.querySelectorAll<HTMLElement>('[data-tq]')) {
      const picked = Array.from(q.querySelectorAll<HTMLInputElement>('input'))
        .filter((i) => i.checked)
        .map((i) => Number(i.value));
      if (picked.length) out[q.id] = picked;
    }
    return out;
  }

  function saveProgress(graded: boolean, score: number, total: number): void {
    if (!asignatura) return;
    safeSet(keyFor(asignatura), serialize({ answers: collectAnswers(), graded, score, total }));
  }

  // Accumulate per-question stats. Called only on a real «Corregir» click — never
  // on restore, so reloading a graded test does not inflate the counters.
  function recordStats(results: GradeResult[]): void {
    if (!asignatura) return;
    const outcomes: Record<string, boolean> = {};
    for (const r of results) if (r.answered) outcomes[r.id] = r.correct;
    if (!Object.keys(outcomes).length) return;
    const key = statsKeyFor(asignatura);
    const state = parseStats(safeGet(key)) ?? { questions: {} };
    safeSet(key, serializeStats(recordGrading(state, outcomes)));
    document.dispatchEvent(new CustomEvent('practica:stats-updated'));
  }

  function restoreProgress(): void {
    if (!asignatura) return;
    const state = parse(safeGet(keyFor(asignatura)));
    if (!state) return;
    const answers = pruneAnswers(state.answers, questionIds());
    for (const [id, picked] of Object.entries(answers)) {
      const q = document.getElementById(id);
      if (!q) continue;
      q.querySelectorAll<HTMLInputElement>('input').forEach((input) => {
        if (picked.includes(Number(input.value))) input.checked = true;
      });
    }
    if (state.graded) {
      // Reuse the bulk grader to repaint the corrected state, then re-emit the
      // score through the same event the page listens to. Deferred so the page's
      // `tq:graded` listener is already registered regardless of script order.
      const { score, total } = gradeAll();
      setTimeout(
        () => document.dispatchEvent(new CustomEvent('tq:graded', { detail: { score, total } })),
        0,
      );
    }
  }

  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    const revealBtn = target.closest('[data-reveal-trigger]');
    if (revealBtn) {
      const q = revealBtn.closest<HTMLElement>('[data-tq]');
      if (q) revealAnswer(q);
      return;
    }
    if (target.closest('[data-reset-trigger]')) {
      if (asignatura) safeRemove(keyFor(asignatura));
      location.reload();
      return;
    }
    if (!target.closest('[data-grade-trigger]')) return;
    const result = gradeAll();
    saveProgress(true, result.score, result.total);
    recordStats(result.results);
    document.dispatchEvent(
      new CustomEvent('tq:graded', { detail: { score: result.score, total: result.total } }),
    );
  });

  // Autosave selections as they change (before grading).
  document.addEventListener('change', (e) => {
    if ((e.target as HTMLElement).closest('[data-tq]')) saveProgress(false, 0, 0);
  });

  restoreProgress();
</script>
