            ['stock', 'number'],
            ['requiereReceta', 'boolean'],
          ],
          rules: [
            {
              t: '<code>stock</code> entre 0 y 500',
              ok: (d) => d.every((x) => x.stock >= 0 && x.stock <= 500),
