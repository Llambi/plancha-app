  /* ============ Resaltado de sintaxis tipo shell ============ */
  function highlight(code) {
    const strings = [];
    let s = code.replace(/(["'])(?:\\.|(?!\1).)*\1/g, (m) => {
      strings.push(m);
      return '\u0000' + String.fromCharCode(97 + strings.length - 1) + '\u0000';
    });
    s = s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
    s = s.replace(/\$[a-zA-Z]+/g, (m) => `<span class="t-op">${m}</span>`);
    s = s.replace(/\b(true|false)\b/g, '<span class="t-bool">$1</span>');
    s = s.replace(/\b(\d+)\b/g, '<span class="t-num">$1</span>');
    s = s.replace(/\b(db|find|sort|select|orderBy)\b/g, '<span class="t-fn">$1</span>');
    s = s.replace(/\u0000([a-z])\u0000/g, (_, ch) => {
      const i = ch.charCodeAt(0) - 97;
      const raw = strings[i].replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
      return `<span class="t-str">${raw}</span>`;
    });
    return s;
  }

  /* ============ Validación del caso práctico ============ */
  function validateCollection(coll, raw) {
    const res = [];
    let docs;
    try {
      docs = JSON.parse(raw);
    } catch (e) {
      return { fatal: `JSON no válido: ${e.message}` };
    }
    if (!Array.isArray(docs)) return { fatal: 'Pega un array de documentos, p. ej. [ {…}, {…} ].' };

    res.push({
      ok: docs.length === coll.exact,
      t: `Número de documentos = ${coll.exact} <span style="opacity:.7">(tienes ${docs.length})</span>`,
    });

    for (const [f, type] of coll.fields) {
      const missing = docs.filter((d) => !(f in d)).length;
      const badType = docs.filter((d) => f in d && !typeCheck[type](d[f])).length;
      const ok = missing === 0 && badType === 0;
      let detail = '';
      if (missing) detail = ` <span style="opacity:.7">(falta en ${missing})</span>`;
      else if (badType) detail = ` <span style="opacity:.7">(tipo erróneo en ${badType})</span>`;
      res.push({
        ok,
        t: `Campo <code>${f}</code> presente y de tipo <code>${typeName[type]}</code>${detail}`,
      });
    }
    for (const r of coll.rules) {
      let ok = false;
      try {
        ok = !!r.ok(docs);
      } catch (e) {
        ok = false;
      }
      res.push({ ok, t: r.t });
    }
    return { results: res };
  }

  /* ============ Render ============ */
  const app = document.getElementById('app');
  const picker = document.getElementById('picker');
  let current = 0;
  const testState = {}; // {exIdx:{selected:[], checked:bool}}

  function buildPicker() {
    picker.innerHTML = '';
    exercises.forEach((ex, i) => {
      const b = document.createElement('button');
      b.textContent = ex.short;
      b.title = ex.title;
      if (i === current) b.classList.add('active');
      b.onclick = () => {
        current = i;
        render();
        window.scrollTo({ top: 0 });
      };
      picker.appendChild(b);
    });
  }

  function render() {
    buildPicker();
    const ex = exercises[current];
    if (!testState[current])
      testState[current] = { selected: Array(ex.test.length).fill(null), checked: false };

    let html = `
  <div class="ex-head">
    <div class="eyebrow">Caso de examen</div>
    <h1>${ex.title}</h1>
