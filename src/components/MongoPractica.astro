  </div>

  <section class="block">
    <div class="block-tag"><span class="n">B1</span> Caso práctico <span class="pct">50 %</span></div>
    <p class="block-sub enunciado">${ex.intro}</p>
    <div class="coll-grid">`;

    ex.colls.forEach((coll, ci) => {
      html += `
      <div class="card coll">
        <h3>db.${coll.name} <span class="count">${coll.exact} documentos</span></h3>
        <div class="coll-body">
          <ul class="fields">${coll.fields.map(([f, t]) => `<li>${f} <em>: ${typeName[t]}</em></li>`).join('')}</ul>
          <ul class="rules">${coll.rules.map((r) => `<li>${r.t}</li>`).join('')}</ul>
          <textarea id="ta-${current}-${ci}" spellcheck="false" placeholder='Pega aquí tu array de documentos JSON:&#10;[&#10;  { ... },&#10;  { ... }&#10;]'></textarea>
          <div class="coll-actions">
            <button class="btn btn-primary" onclick="runValidate(${ci})">Validar colección</button>
            <button class="btn btn-ghost" onclick="loadExample(${ci})">Cargar ejemplo válido</button>
          </div>
          <div class="checkresults" id="cr-${current}-${ci}"></div>
          <div class="verdict" id="vd-${current}-${ci}"></div>
        </div>
      </div>`;
    });

    html += `</div>
    <div class="entrega">📦 <div><b>Entrega:</b> exporta únicamente las colecciones creadas y entrégalas en formato ZIP. Usa <span class="kbd">mongoexport</span> o "Export Collection" en MongoDB Compass.</div></div>
  </section>

  <section class="block">
    <div class="block-tag"><span class="n">B2</span> Test de consultas <span class="pct">50 %</span></div>
    <p class="block-sub">Selecciona la consulta MongoDB correcta en cada caso. Pulsa <b>Corregir test</b> al terminar.</p>`;

    ex.test.forEach((qq, qi) => {
      html += `<div class="card pad q">
      <div class="qhead"><div class="qnum">${qi + 1}</div><div class="qtext">${qq.q}</div></div>
      <div class="opts" id="opts-${current}-${qi}">`;
      qq.opts.forEach((o, oi) => {
        const letter = String.fromCharCode(97 + oi);
        html += `<label class="opt" id="opt-${current}-${qi}-${oi}">
        <input type="radio" class="opt-radio" name="q-${current}-${qi}" onchange="pick(${qi},${oi})" />
        <div class="letter">${letter}</div><pre>${highlight(o.c)}</pre></label>`;
      });
      html += `</div><div class="feedback" id="fb-${current}-${qi}"></div></div>`;
    });

    html += `<div class="test-actions">
      <button class="btn btn-primary" onclick="correctTest()">Corregir test</button>
      <button class="btn btn-ghost" onclick="resetTest()">Reiniciar</button>
      <div class="scorebox" id="score"></div>
    </div>
    <p class="hint">Consejo: razona por qué cada distractor es incorrecto antes de mirar la corrección. Los errores se repiten (usar <code>=</code>, comillas en booleanos, falta de <code>$</code>, colección en singular…).</p>
  </section>`;

    app.innerHTML = html;
    // restore test selections if any
    const st = testState[current];
    st.selected.forEach((sel, qi) => {
      if (sel !== null) markSelected(qi, sel);
    });
    if (st.checked) applyCorrection(false);
  }

  function markSelected(qi, oi) {
    const ex = exercises[current];
    ex.test[qi].opts.forEach((_, k) => {
      document.getElementById(`opt-${current}-${qi}-${k}`).classList.remove('sel');
    });
    const el = document.getElementById(`opt-${current}-${qi}-${oi}`);
    el.classList.add('sel');
    el.querySelector('input').checked = true;
  }

  window.pick = function (qi, oi) {
    const st = testState[current];
    if (st.checked) return;
    st.selected[qi] = oi;
    markSelected(qi, oi);
  };

  window.correctTest = function () {
    const st = testState[current];
    st.checked = true;
    applyCorrection(true);
  };

  function applyCorrection(scroll) {
    const ex = exercises[current];
    let correctCount = 0;
    ex.test.forEach((qq, qi) => {
      const sel = testState[current].selected[qi];
      qq.opts.forEach((o, oi) => {
        const el = document.getElementById(`opt-${current}-${qi}-${oi}`);
        el.classList.add('locked');
        el.classList.remove('sel');
        if (oi === qq.correct) el.classList.add('correct');
        else if (oi === sel) el.classList.add('wrong');
      });
      const fb = document.getElementById(`fb-${current}-${qi}`);
      const ok = sel === qq.correct;
      if (ok) correctCount++;
      const chosen =
        sel === null ? '<i>sin responder</i>' : `opción <b>${String.fromCharCode(97 + sel)}</b>`;
      fb.className = 'feedback show ' + (ok ? 'good' : 'bad');
      fb.innerHTML =
        (ok
          ? '✓ Correcto. '
          : `✗ Has elegido ${chosen}. La correcta es <b>${String.fromCharCode(97 + qq.correct)}</b>. `) +
        qq.opts[qq.correct].j +
        (ok
          ? ''
          : `<br><span style="opacity:.85">Tu opción: ${sel === null ? '—' : qq.opts[sel].j}</span>`);
    });
    const total = ex.test.length;
    const sb = document.getElementById('score');
    const pass = correctCount >= Math.ceil(total / 2);
    sb.className = 'scorebox ' + (correctCount === total ? 'pass' : pass ? '' : 'fail');
    sb.innerHTML = `Aciertos: <b>${correctCount}/${total}</b> · Bloque 2: <b>${((correctCount / total) * 50).toFixed(1).replace('.0', '')} / 50</b>`;
  }

  window.resetTest = function () {
    testState[current] = {
      selected: Array(exercises[current].test.length).fill(null),
      checked: false,
    };
    render();
  };

  window.runValidate = function (ci) {
    const coll = exercises[current].colls[ci];
    const raw = document.getElementById(`ta-${current}-${ci}`).value.trim();
    const cr = document.getElementById(`cr-${current}-${ci}`);
    const vd = document.getElementById(`vd-${current}-${ci}`);
    if (!raw) {
      cr.className = 'checkresults show';
      cr.innerHTML = `<div class="chk bad"><span class="ic">!</span><span>Pega tus documentos JSON antes de validar.</span></div>`;
      vd.className = 'verdict';
      return;
    }
    const out = validateCollection(coll, raw);
    cr.className = 'checkresults show';
    if (out.fatal) {
      cr.innerHTML = `<div class="chk bad"><span class="ic">✗</span><span>${out.fatal}</span></div>`;
      vd.className = 'verdict';
      return;
    }
    cr.innerHTML = out.results
      .map(
        (r) =>
          `<div class="chk ${r.ok ? 'ok' : 'bad'}"><span class="ic">${r.ok ? '✓' : '✗'}</span><span>${r.t}</span></div>`,
      )
      .join('');
    const allOk = out.results.every((r) => r.ok);
    vd.className = 'verdict show ' + (allOk ? 'pass' : 'fail');
    vd.textContent = allOk
      ? `✓ La colección db.${coll.name} cumple todas las condiciones.`
      : `✗ Aún hay condiciones sin cumplir en db.${coll.name}.`;
  };

