            { c: 'db.medicamentos.find({ nombre, stock })', j: J.projShort() },
            { c: 'db.medicamentos.select({ nombre: 1, stock: 1 })', j: J.projSelect() },
            { c: 'db.medicamentos.find({}, { nombre: true, stock: true })', j: J.projTrue() },
          ],
