          correct: 0,
          opts: [
            { c: 'db.habitaciones.find({}, { numero: 1, precioNoche: 1, _id: 0 })', j: J.okProj() },
            { c: 'db.habitaciones.find({ numero, precioNoche })', j: J.projShort() },
            { c: 'db.habitaciones.select({ numero: 1, precioNoche: 1 })', j: J.projSelect() },
            { c: 'db.habitaciones.find({}, { numero: true, precioNoche: true })', j: J.projTrue() },
          ],
        },
        {
          q: 'Obtener las reservas con más de 3 noches.',
          correct: 2,
          opts: [
            { c: 'db.reservas.find({ noches > 3 })', j: J.bareGt() },
            { c: 'db.reserva.find({ noches: { $gt = 3 } })', j: J.gtEq() },
            { c: 'db.reservas.find({ noches: { $gt: 3 } })', j: J.okGt(3) },
            { c: 'db.reservas.find({ noches: "3" })', j: J.strNum() },
          ],
        },
        {
          q: 'Listar las reservas ordenadas por número de noches de mayor a menor.',
          correct: 3,
          opts: [
            { c: 'db.reservas.sort({ noches: -1 })', j: J.sortNoFind() },
            { c: 'db.reservas.find().orderBy({ noches: "desc" })', j: J.orderBy() },
            { c: 'db.reservas.find().sort(noches: -1)', j: J.sortNoBraces() },
            { c: 'db.reservas.find().sort({ noches: -1 })', j: J.okSortDesc() },
          ],
        },
      ],
    },
    {
      short: 'Ej. 3',
      title: 'Ejercicio 3 — Gestión de medicamentos',
      db: 'farmacia_central',
      source: 'Repositorio oficial · sin resolver 🤔',
      intro:
        'Crea la base de datos <b>farmacia_central</b> con exactamente dos colecciones: <b>medicamentos</b> y <b>dispensaciones</b>.',
      colls: [
