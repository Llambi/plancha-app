            ['fecha', 'date'],
            ['validada', 'boolean'],
          ],
          rules: [
            {
              t: '<code>unidades</code> entre 1 y 30',
              ok: (d) => d.every((x) => x.unidades >= 1 && x.unidades <= 30),
            },
            {
              t: 'Al menos 3 dispensaciones con <code>validada: true</code>',
              ok: (d) => d.filter((x) => x.validada === true).length >= 3,
            },
            {
              t: 'Al menos una dispensación de más de 10 unidades',
