---
/**
 * MongoPractica — validador de consultas MongoDB (práctica de examen interactiva).
 * El script de la app va is:inline y contiene los datos de los ejercicios junto
 * con su lógica de validación (las reglas son funciones). El CSS propio está
 * scopeado bajo `.mongo-practica`. Las preguntas/respuestas NO se modifican.
 */
---

<div class="mongo-practica">
  <div class="mongo-header">
    <div class="bar">
      <div class="mark">
        <div class="leaf">{}</div>
        <div>
          <b>Práctica de examen · MongoDB</b>
          <span>Bases de Datos Avanzadas · estilo examen final</span>
        </div>
      </div>
      <nav class="picker" id="picker"></nav>
    </div>
  </div>
  <div id="app" class="mongo-main"></div>
  <footer class="mongo-footer">
    Herramienta de práctica basada en el repositorio <code
      >jarturomora/bases-datos-avanzadas-gii</code
    >. Los ejercicios 1–4 reproducen los del repositorio; los ejercicios 5–6 son originales en el
    mismo formato para practicar más. El validador comprueba las condiciones en tu navegador; no
    sustituye a probar las consultas en MongoDB.
  </footer>
</div>

<script is:inline>
  /* ============ Helpers de justificación ============ */
  const J = {
    okEq: (c) =>
      `Correcto. Filtra por igualdad con la forma <code>{ campo: valor }</code> sobre la colección <code>${c}</code>, con el nombre en plural y el tipo de dato correcto.`,
    assign: () =>
      `Usa <code>=</code> (asignación) en vez de <code>:</code> dentro del objeto. El filtro de <code>find()</code> es un documento: <code>{ campo: valor }</code>.`,
    strBool: () =>
      `Compara contra la cadena <code>"true"</code> en lugar del booleano <code>true</code>; no coincidiría con un campo de tipo boolean.`,
    strFilter: () =>
      `Pasa una cadena de texto como filtro. <code>find()</code> espera un documento <code>{ }</code> como criterio, no un string.`,
    wrongColl: (c) =>
      `El nombre de la colección es incorrecto (debe ser <code>${c}</code>, en plural).`,
    badChain: () =>
      `Invierte el orden: lo correcto es <code>db.coleccion.find(...)</code>, no <code>db.find.coleccion(...)</code>.`,
    okGt: (n) =>
      `Correcto. La comparación se escribe como objeto anidado en el campo: <code>{ campo: { $gt: ${n} } }</code>.`,
    bareGt: () =>
      `<code>></code> no es un operador válido dentro del documento de consulta; hay que usar el operador <code>$gt</code>.`,
    gtEq: () =>
      `<code>$gt = ...</code> mezcla operador con <code>=</code>. La forma válida es <code>$gt: valor</code> y, además, la colección está mal escrita.`,
    opOutside: () =>
      `Coloca el operador fuera del campo. Debe ir dentro: <code>{ campo: { $gt: n } }</code>.`,
    strNum: () =>
      `Compara contra una cadena (<code>"n"</code>) en vez de un número, y no usa operador de comparación.`,
    okProj: () =>
      `Correcto. La proyección <code>{ campo: 1, _id: 0 }</code> muestra solo esos campos y oculta <code>_id</code>.`,
    projShort: () =>
      `<code>{ campo, otro }</code> no es sintaxis válida de proyección; hay que indicar <code>campo: 1</code>.`,
    projSelect: () =>
      `<code>.select()</code> no existe en MongoDB; la proyección va como segundo argumento de <code>find()</code>.`,
    projTrue: () =>
      `<code>{ campo: 1 }</code> proyecta el campo pero NO oculta <code>_id</code>, así que devuelve un campo de más respecto a lo pedido.`,
    okSortDesc: () =>
      `Correcto. Se ordena sobre el cursor: <code>.find().sort({ campo: -1 })</code> (descendente).`,
    okSortAsc: () =>
      `Correcto. Se ordena sobre el cursor: <code>.find().sort({ campo: 1 })</code> (ascendente).`,
    sortNoFind: () =>
      `<code>.sort()</code> se aplica al cursor que devuelve <code>find()</code>. <code>db.coleccion.sort(...)</code> no es válido.`,
    orderBy: () =>
      `<code>.orderBy()</code> no es un método de MongoDB; la ordenación se hace con <code>.sort()</code>.`,
    sortNoBraces: () =>
      `<code>sort(campo: -1)</code> no es válido: el argumento debe ser un objeto <code>{ campo: -1 }</code>.`,
    okLte: () =>
      `Correcto. "Menor o igual" es <code>$lte</code> (la <em>e</em> es de <em>equal</em>).`,
    ltForLte: () =>
      `<code>$lt</code> es "estrictamente menor". Para "menor o igual" se necesita <code>$lte</code>.`,
    lteOutside: () =>
      `El operador va dentro del campo: <code>{ edad: { $lte: 30 } }</code>, no <code>{ $lte: { edad: 30 } }</code>.`,
  };

  /* ============ Validadores de tipo ============ */
  const isStr = (v) => typeof v === 'string';
  const isNum = (v) => typeof v === 'number' && !Number.isNaN(v);
  const isBool = (v) => typeof v === 'boolean';
  const isDate = (v) =>
    (v && typeof v === 'object' && '$date' in v) ||
    (typeof v === 'string' && /\d{4}-\d{2}-\d{2}/.test(v));
  const typeName = { string: 'string', number: 'number', boolean: 'boolean', date: 'date' };
  const typeCheck = { string: isStr, number: isNum, boolean: isBool, date: isDate };

  /* ============ Datos de los ejercicios ============ */
  const exercises = [
    {
      short: 'Ej. 1',
      title: 'Ejercicio 1 — Video Club',
      db: 'videoclub',
      source: 'Repositorio oficial · resuelto ✅',
      intro:
        'Un video club necesita registrar información básica sobre sus <b>películas</b> y sus <b>clientes</b>. Crea la base de datos <b>videoclub</b> con exactamente dos colecciones e inserta los datos cumpliendo todas las condiciones.',
      colls: [
        {
          name: 'peliculas',
          exact: 6,
          fields: [
            ['titulo', 'string'],
            ['genero', 'string'],
            ['anio', 'number'],
            ['precio_alquiler', 'number'],
          ],
          rules: [
            {
              t: '<code>anio</code> entre 2000 y 2022',
              ok: (d) => d.every((x) => x.anio >= 2000 && x.anio <= 2022),
            },
            {
              t: '<code>precio_alquiler</code> entre 2 y 6 (incl.)',
              ok: (d) => d.every((x) => x.precio_alquiler >= 2 && x.precio_alquiler <= 6),
            },
            {
              t: 'Al menos 2 películas de género "Acción"',
              ok: (d) => d.filter((x) => x.genero === 'Acción').length >= 2,
            },
          ],
        },
        {
          name: 'clientes',
          exact: 4,
          fields: [
            ['nombre', 'string'],
            ['edad', 'number'],
            ['socio_activo', 'boolean'],
          ],
          rules: [
            {
              t: '<code>edad</code> entre 18 y 65',
              ok: (d) => d.every((x) => x.edad >= 18 && x.edad <= 65),
            },
            {
              t: 'Al menos 2 clientes con <code>socio_activo: true</code>',
              ok: (d) => d.filter((x) => x.socio_activo === true).length >= 2,
            },
          ],
        },
      ],
      test: [
        {
          q: 'Obtener todas las películas del género <code>"Acción"</code>.',
          correct: 2,
          opts: [
            { c: 'db.peliculas.find("genero: Acción")', j: J.strFilter() },
            { c: 'db.peliculas.find({ genero = "Acción" })', j: J.assign() },
            { c: 'db.peliculas.find({ genero: "Acción" })', j: J.okEq('peliculas') },
            { c: 'db.find.peliculas({ genero: "Acción" })', j: J.badChain() },
          ],
        },
        {
          q: 'Mostrar las películas cuyo <code>precio_alquiler</code> sea mayor a 4.',
          correct: 1,
          opts: [
            { c: 'db.peliculas.find({ precio_alquiler: > 4 })', j: J.bareGt() },
            { c: 'db.peliculas.find({ precio_alquiler: { $gt: 4 } })', j: J.okGt(4) },
            { c: 'db.peliculas.find({ $gt: { precio_alquiler: 4 } })', j: J.opOutside() },
            { c: 'db.peliculas.find(precio_alquiler > 4)', j: J.bareGt() },
          ],
        },
        {
          q: 'Obtener los clientes que tengan <code>socio_activo</code> en true.',
          correct: 2,
          opts: [
            { c: 'db.clientes.find({ socio_activo = true })', j: J.assign() },
            { c: 'db.clientes.find("socio_activo: true")', j: J.strFilter() },
            { c: 'db.clientes.find({ socio_activo: true })', j: J.okEq('clientes') },
            { c: 'db.find({ socio_activo: true })', j: J.wrongColl('clientes') },
          ],
        },
        {
          q: 'Mostrar los clientes cuya <code>edad</code> sea menor o igual a 30.',
          correct: 2,
          opts: [
            { c: 'db.clientes.find({ edad: { $lt: 30 } })', j: J.ltForLte() },
            { c: 'db.clientes.find({ edad <= 30 })', j: J.bareGt() },
            { c: 'db.clientes.find({ edad: { $lte: 30 } })', j: J.okLte() },
            { c: 'db.clientes.find({ $lte: { edad: 30 } })', j: J.lteOutside() },
          ],
        },
      ],
    },
    {
      short: 'Ej. 2',
