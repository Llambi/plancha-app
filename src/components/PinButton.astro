---
/**
 * PinButton — the pin/marker toggle shown on cards and outline branches that
 * can be pinned for the minimap (`Minimap.astro`). Markup only: click handling,
 * persistence and the pinned-state styling live in `Minimap.astro`'s global
 * styles/script, since the same visuals also apply to sub-branch pin buttons
 * injected at runtime (see `ensureSubAnchors` there).
 */
interface Props {
  label?: string;
  small?: boolean;
}
const { label = 'Fijar', small = false } = Astro.props;
---

<button
  class={`pin-btn${small ? ' pin-btn-sm' : ''}`}
  type="button"
  data-mm-pin
  aria-label={label}
  title={label}
>
  <svg class="pin-svg" viewBox="0 0 24 24" aria-hidden="true">
    <path
      d="M7 3h10a1 1 0 0 1 1 1v16.5a.6.6 0 0 1-.9.52L12 18l-5.1 3.02A.6.6 0 0 1 6 20.5V4a1 1 0 0 1 1-1z"
    ></path>
  </svg>
</button>
