---
/**
 * SoaGuide — guía paginada de SOA portada del HTML original (verbatim vía
 * set:html) dentro del shell unificado. Reproduce la paginación por capítulos
 * (showChapter/prev/next) y el acordeón de soluciones (toggleSol). El "Test de
 * Examen" se renderiza como una página más con componentes TestQuestion.
 *
 * El CSS de contenido de SOA va scopeado bajo `.soa-guide` (is:global porque el
 * HTML se inyecta con set:html). Solo se carga en la página de la guía SOA.
 */
import TestQuestion from './TestQuestion.astro';

interface Chapter {
  chapter: string;
  num: string;
  titulo: string;
  badge?: string;
  html: string;
}
interface QuizQ {
  id: string;
  type: 'single' | 'multi';
  question: string;
  options: string[];
  correct: number[];
  apariciones?: number;
}
interface Props {
  chapters: Chapter[];
  quiz: QuizQ[];
}
const { chapters, quiz } = Astro.props;
const quizIdx = chapters.length; // índice de la página del quiz
---

<div class="soa-guide">
  <nav class="soa-nav" aria-label="Capítulos de la guía">
    {
      chapters.map((c, i) => (
        <button class={`soa-chip${i === 0 ? ' active' : ''}`} type="button" data-ch={i}>
          <span class="soa-chip-num">{c.num}</span>
          <span class="soa-chip-title">{c.titulo}</span>
          {c.badge && <span class="soa-chip-badge">{c.badge}</span>}
        </button>
      ))
    }
    <button class="soa-chip quiz" type="button" data-ch={quizIdx}>
      <span class="soa-chip-num">🎯</span>
      <span class="soa-chip-title">Test de Examen</span>
      <span class="soa-chip-badge">{quiz.length} Qs</span>
    </button>
  </nav>

  {
    chapters.map((c, i) => (
      <div id={c.chapter} class={`chapter-page${i === 0 ? ' active' : ''}`} set:html={c.html} />
    ))
  }

  <div class={`chapter-page${chapters.length === 0 ? ' active' : ''}`} id="soa-quiz">
    <div class="chapter-banner">
      <div class="ch-label">Test de Examen</div>
      <h1>80 preguntas tipo test</h1>
      <p class="ch-desc">
        Preguntas de exámenes anteriores. La etiqueta «× n en exámenes» indica cuántas veces
        apareció cada una. Marca y pulsa «Corregir».
      </p>
    </div>
    <div class="content-area">
      {
        quiz.map((q, i) => (
          <TestQuestion
            id={q.id}
            type={q.type}
            question={q.question}
            options={q.options}
            correct={q.correct}
            apariciones={q.apariciones}
            num={i + 1}
          />
        ))
      }
      <div class="soa-quiz-foot">
        <button class="soa-grade" type="button" data-grade-trigger> Corregir test </button>
        <span class="soa-score" role="status" aria-live="polite"></span>
      </div>
    </div>
  </div>
</div>

<script>
  // Paginación + acordeón de soluciones (funciones globales que usan los
  // onclick incrustados en el HTML de los capítulos del original).
  const pages = Array.from(document.querySelectorAll<HTMLElement>('.soa-guide .chapter-page'));
  const chips = Array.from(document.querySelectorAll<HTMLElement>('.soa-guide .soa-chip'));

  function showChapter(idx: number) {
    if (idx < 0 || idx >= pages.length) return;
    pages.forEach((p) => p.classList.remove('active'));
    chips.forEach((c) => c.classList.remove('active'));
    pages[idx].classList.add('active');
    chips[idx]?.classList.add('active');
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }
  function currentIdx() {
    return pages.findIndex((p) => p.classList.contains('active'));
  }
  function nextChapter() {
    showChapter(currentIdx() + 1);
  }
  function prevChapter() {
    showChapter(currentIdx() - 1);
  }
  function toggleSol(el: HTMLElement) {
    el.closest('.solucion')?.classList.toggle('open');
  }
  // Exponer para los onclick incrustados.
  Object.assign(window, { showChapter, nextChapter, prevChapter, toggleSol });

  chips.forEach((chip) => {
    chip.addEventListener('click', () => showChapter(Number(chip.dataset.ch)));
  });

  // Deep-link: abre el capítulo cuyo id coincide con location.hash (#chN, #soa-quiz)
  // antes de hacer scroll, porque los capítulos están display:none hasta activarse.
  function showFromHash() {
    const id = decodeURIComponent(location.hash.replace(/^#/, ''));
    if (!id) return;
    const idx = pages.findIndex((p) => p.id === id);
    if (idx >= 0) {
      showChapter(idx);
    }
  }
  showFromHash();
  window.addEventListener('hashchange', showFromHash);

  document.addEventListener('tq:graded', (e) => {
    const { score, total } = (e as CustomEvent).detail;
    const el = document.querySelector('.soa-score');
    if (el) el.textContent = `Aciertos: ${score} / ${total}`;
  });
</script>

<style is:global define:vars={{}}>
  /* === Fuentes (fallback de sistema si no cargan) === */

  /* === Tokens SOA (scopeados) === */
  .soa-guide {
    --mcg-red: #c41230;
    --mcg-red-dark: #9b0e24;
    --mcg-red-light: #f5e6e9;
    --mcg-blue: #1a3a6b;
    --mcg-blue-mid: #2b5c9e;
    --mcg-blue-light: #e8eef7;
    --mcg-gold: #c8860a;
    --mcg-gold-bg: #fef6e4;
    /* text-on-gold-bg only (issue #78): --mcg-gold itself falls short of
       4.5:1 on --mcg-gold-bg in light mode; kept separate from --mcg-gold
       since that one is also used for borders (no contrast requirement) and
       for .template-label over a fixed dark background (already passes). */
    --mcg-gold-text: #8a5c07;
    --mcg-green: #1b6637;
    --mcg-green-bg: #e8f5ee;
    --mcg-gray: #4a4a4a;
    --mcg-gray-light: #f5f5f5;
    --mcg-border: #cacaca;
    --text-body: #2d2d2d;
    --text-head: #1a1a1a;
    --content-max: 920px;
    --serif: 'Merriweather', Georgia, 'Times New Roman', serif;
    --mono: 'Source Code Pro', ui-monospace, 'SFMono-Regular', Menlo, monospace;
    font-size: 15px;
    line-height: 1.75;
    color: var(--text-body);
  }
  :root[data-theme='dark'] .soa-guide {
    --mcg-gray-light: #1d2430;
    --mcg-border: #33404f;
    --mcg-blue-light: #16243c;
    --mcg-gold-bg: #2a2310;
    --mcg-gold-text: #c8860a;
    --mcg-red-light: #2c1418;
    --mcg-green-bg: #13271b;
    --text-body: #dfe3e8;
    --text-head: #f2f4f7;
    --mcg-gray: #b8c2cc;
  }

  /* === Chip nav === */
  .soa-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.6rem;
  }
  .soa-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    cursor: pointer;
    font: inherit;
    font-size: 0.82rem;
    color: var(--site-muted);
    background: var(--site-surface);
    border: 1px solid var(--site-line);
    border-radius: 999px;
    padding: 0.4rem 0.85rem;
    transition:
      border-color 0.15s,
      color 0.15s;
  }
  .soa-chip:hover {
    color: var(--site-ink);
    border-color: var(--mcg-red);
  }
  .soa-chip.active {
    color: #fff;
    background: var(--mcg-red);
    border-color: var(--mcg-red);
  }
  .soa-chip-num {
    font-weight: 800;
  }
  .soa-chip.active .soa-chip-num {
    color: #fff;
  }
  .soa-chip-badge {
    font-size: 0.66rem;
    font-weight: 700;
    /* issue #78: 0.8 (and even 0.9) dropped this below 4.5:1 for the
       inactive-chip case (muted color on white); 0.97 keeps both that and
       the active (white-on-red) case comfortably above the threshold. */
    opacity: 0.97;
  }

  /* === Páginas de capítulo === */
  .soa-guide .chapter-page {
    display: none;
  }
  .soa-guide .chapter-page.active {
    display: block;
  }
  .soa-guide .chapter-banner {
    background: linear-gradient(135deg, var(--mcg-blue) 0%, var(--mcg-blue-mid) 100%);
    padding: 36px 32px 32px;
    color: #fff;
    border-radius: 12px;
    margin-bottom: 8px;
  }
  .soa-guide .chapter-banner .ch-label {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.65);
    margin-bottom: 8px;
  }
  .soa-guide .chapter-banner h1 {
    font-family: var(--serif);
    font-size: 1.9rem;
    font-weight: 700;
    line-height: 1.25;
    margin-bottom: 14px;
  }
