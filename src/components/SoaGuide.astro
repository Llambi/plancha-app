    background: var(--mcg-blue-light);
  }
  .soa-guide .key-box {
    border: 1px solid var(--mcg-gold);
    border-left: 5px solid var(--mcg-gold);
    background: var(--mcg-gold-bg);
  }
  .soa-guide .exam-box {
    border: 1px solid var(--mcg-red);
    border-left: 5px solid var(--mcg-red);
    background: var(--mcg-red-light);
  }
  .soa-guide .example-box {
    border: 1px solid var(--mcg-green);
    border-left: 5px solid var(--mcg-green);
    background: var(--mcg-green-bg);
  }
  .soa-guide .box-label {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    margin-bottom: 6px;
  }
  .soa-guide .def-box .box-label {
    color: var(--mcg-blue-mid);
  }
  .soa-guide .key-box .box-label {
    color: var(--mcg-gold-text);
  }
  .soa-guide .exam-box .box-label {
    color: var(--mcg-red);
  }
  .soa-guide .example-box .box-label {
    color: var(--mcg-green);
  }
  .soa-guide .def-box .box-term {
    font-family: var(--serif);
    font-weight: 700;
    font-size: 15px;
    color: var(--mcg-blue-mid);
    margin-bottom: 6px;
  }
  .soa-guide .def-box p,
  .soa-guide .key-box p,
  .soa-guide .exam-box p,
  .soa-guide .example-box p {
    font-size: 14px;
  }

  /* Tablas */
  .soa-guide .mcg-table-wrap {
    margin: 24px 0;
    overflow-x: auto;
  }
  .soa-guide .mcg-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 14px;
  }
  .soa-guide .mcg-table th {
    background: var(--mcg-blue);
    color: #fff;
    padding: 10px 14px;
    text-align: left;
    font-weight: 600;
    font-size: 13px;
  }
  .soa-guide .mcg-table td {
    padding: 9px 14px;
    border-bottom: 1px solid var(--mcg-border);
    vertical-align: top;
  }
  .soa-guide .mcg-table tr:nth-child(even) td {
    background: var(--mcg-gray-light);
  }
  .soa-guide .mcg-table .red-cell {
    color: var(--mcg-red);
    font-weight: 700;
  }
  .soa-guide .mcg-table .green-cell {
    color: var(--mcg-green);
    font-weight: 700;
  }

  /* Paso a paso */
  .soa-guide .paso-card {
    margin: 22px 0;
    border-radius: 8px;
    border: 1px solid var(--mcg-border);
    background: var(--site-surface);
    box-shadow: var(--site-shadow);
    overflow: hidden;
  }
  .soa-guide .paso-header {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 14px 20px;
    background: var(--mcg-gray-light);
    border-bottom: 1px solid var(--mcg-border);
  }
  .soa-guide .paso-num {
    background: var(--mcg-red);
    color: #fff;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 14px;
    flex-shrink: 0;
    font-family: var(--serif);
  }
  .soa-guide .paso-title {
    font-family: var(--serif);
    font-weight: 700;
    font-size: 15px;
    color: var(--mcg-blue-mid);
    line-height: 1.3;
  }
  .soa-guide .paso-subtitle {
    font-size: 11px;
    color: var(--site-muted);
    margin-top: 2px;
    font-style: italic;
  }
  .soa-guide .paso-body {
    padding: 18px 20px;
  }
  .soa-guide .paso-theory {
    font-size: 14px;
    color: var(--text-body);
    line-height: 1.75;
    margin-bottom: 12px;
  }

  /* Bloques de código */
  .soa-guide .code-block,
  .soa-guide .template-box {
    background: #1e2235;
    color: #e2e8f0;
    border-radius: 6px;
    padding: 16px 20px;
    font-family: var(--mono);
    font-size: 13px;
    line-height: 1.7;
    overflow-x: auto;
    margin: 12px 0;
    white-space: pre;
  }
  .soa-guide .template-box {
    background: #0f1729;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }
  .soa-guide .template-label {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--mcg-gold);
    margin-bottom: 8px;
  }
  .soa-guide .code-block .kw {
    color: #bb86fc;
  }
  .soa-guide .code-block .fn {
    color: #82aaff;
  }
  .soa-guide .code-block .str {
    color: #c3e88d;
  }
  .soa-guide .code-block .cm {
    color: #676e95;
    font-style: italic;
  }
  .soa-guide .code-block .pp {
    color: #f78c6c;
  }
  .soa-guide .code-block .num {
    color: #f78c6c;
  }
  .soa-guide .code-block .ty {
    color: #ffcb6b;
  }
  .soa-guide .code-block .ps-cmd {
    color: #82aaff;
  }
  .soa-guide .code-block .ps-param {
    color: #89ddff;
  }
  .soa-guide .code-block .ps-var {
    color: #f07178;
  }
  .soa-guide .code-block .ps-str {
    color: #c3e88d;
  }
  .soa-guide .code-block .bash-cmd {
    color: #82aaff;
  }
  .soa-guide .code-block .bash-var {
    color: #f07178;
  }
  .soa-guide .code-block .bash-str {
    color: #c3e88d;
  }

  /* Ejercicio + solución acordeón */
  .soa-guide .ejercicio {
    background: var(--mcg-gold-bg);
    border-left: 4px solid var(--mcg-gold);
    border-radius: 0 4px 4px 0;
    padding: 12px 16px;
    margin: 14px 0 8px;
  }
  .soa-guide .ejercicio .ej-label {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--mcg-gold-text);
    margin-bottom: 5px;
  }
  .soa-guide .ejercicio p {
    font-size: 14px;
    color: var(--text-body);
  }
  .soa-guide .solucion {
